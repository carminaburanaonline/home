<TEI>
  <teiHeader />
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB169_PB-lg-1">
          <l n="1" xml:id="CB169_PB-l-1">L&#8217;&#233;toile si plaisante &#224; voir est assombrie,</l>
          <l n="2" rend="indent(1)" xml:id="CB169_PB-l-2">un nuage couvre son c&#339;ur,</l>
          <l n="3" xml:id="CB169_PB-l-3">et le rire de ma bouche languit,</l>
          <l n="4" rend="indent(1)" xml:id="CB169_PB-l-4">priv&#233; de son bonheur.</l>
          <l n="5" xml:id="CB169_PB-l-5">J&#8217;ai bien raison d&#8217;&#234;tre afflig&#233; :</l>
          <l n="6" xml:id="CB169_PB-l-6">car ma bien aim&#233;e m&#8217;est cach&#233;e,</l>
          <l n="7" xml:id="CB169_PB-l-7">en qui fleurit mon ardeur,</l>
          <l n="8" rend="indent(1)" xml:id="CB169_PB-l-8">j&#8217;y suis tout attach&#233;.</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB169_PB-lg-2">
          <l n="1" xml:id="CB169_PB-l-9">Elle brille au premier rang</l>
          <l n="2" rend="indent(1)" xml:id="CB169_PB-l-10">du ch&#339;ur d&#8217;Amour,</l>
          <l n="3" xml:id="CB169_PB-l-11">elle dont le regard</l>
          <l n="4" xml:id="CB169_PB-l-12">renvoie la lumi&#232;re du soleil,</l>
          <l n="5" rend="indent(1)" xml:id="CB169_PB-l-13">et peut &#224; lui seul</l>
          <l n="6" rend="indent(1)" xml:id="CB169_PB-l-14">servir de miroir.</l>
          <l n="7" xml:id="CB169_PB-l-15">C&#8217;est elle que je v&#233;n&#232;re,</l>
          <l n="8" xml:id="CB169_PB-l-16">que je veux sur cette terre,</l>
          <l n="9" xml:id="CB169_PB-l-17">c&#8217;est ma seule volont&#233;.</l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB169_PB-lg-3">
          <l n="1" xml:id="CB169_PB-l-18">Je plains le temps d&#8217;une solitude</l>
          <l n="2" rend="indent(1)" xml:id="CB169_PB-l-19">si prolong&#233;e,</l>
          <l n="3" xml:id="CB169_PB-l-20">moi qui d&#233;robais, gr&#226;ce aux occasions</l>
          <l n="4" rend="indent(1)" xml:id="CB169_PB-l-21">de la nuit,</l>
          <l n="5" xml:id="CB169_PB-l-22">les baisers de sa bouche,</l>
          <l n="6" xml:id="CB169_PB-l-23">d&#8217;o&#249; coule un d&#233;licieux parfum,</l>
          <l n="7" xml:id="CB169_PB-l-24">quand la douce cannelle</l>
          <l n="8" xml:id="CB169_PB-l-25">entr&#8217;ouvre la maison du c&#339;ur.</l>
        </lg>
        <lg type="strophe" n="IV" xml:id="CB169_PB-lg-4">
          <l n="1" xml:id="CB169_PB-l-26">Elle languit cependant, elle manque</l>
          <l n="2" rend="indent(1)" xml:id="CB169_PB-l-27">du r&#233;confort esp&#233;r&#233;,</l>
          <l n="3" xml:id="CB169_PB-l-28">et se perd sa jeunesse en fleur.</l>
          <l n="4" xml:id="CB169_PB-l-29">Qu&#8217;un si grand espace entre eux</l>
          <l n="5" xml:id="CB169_PB-l-30">cesse de les s&#233;parer, pour que cette division</l>
          <l n="6" rend="indent(1)" xml:id="CB169_PB-l-31">procure des droits assur&#233;s</l>
          <l n="7" xml:id="CB169_PB-l-32">&#224; ceux qui sont faits pour se joindre.</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>