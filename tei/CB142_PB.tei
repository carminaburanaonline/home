<TEI>
  <teiHeader />
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB142_PB-lg-1">
          <l n="1" xml:id="CB142_PB-l-1">
            <seg type="hemistich">Voici venir le temps fleuri,</seg>
            <seg type="hemistich">car les fleurs se dressent,</seg>
          </l>
          <l n="2" xml:id="CB142_PB-l-2">
            <seg type="hemistich">les usages de printemps</seg>
            <seg type="hemistich">en tout apparaissent.</seg>
          </l>
          <l n="3" xml:id="CB142_PB-l-3">
            <seg type="hemistich">La douceur du temps r&#233;pare</seg>
            <seg type="hemistich">ce que le froid a d&#233;truit,</seg>
          </l>
          <l n="4" xml:id="CB142_PB-l-4">
            <seg type="hemistich">les chatoyantes couleurs</seg>
            <seg type="hemistich">nous montrent qu&#8217;il en est ainsi.</seg>
          </l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB142_PB-lg-2">
          <l n="1" xml:id="CB142_PB-l-5">
            <seg type="hemistich">Les pr&#233;s sont remplis de fleurs,</seg>
            <seg type="hemistich">allons nous y d&#233;lasser !</seg>
          </l>
          <l n="2" xml:id="CB142_PB-l-6">
            <seg type="hemistich">Jeunes filles, avec les clercs</seg>
            <seg type="hemistich">ensemble promenons-nous, </seg>
          </l>
          <l n="3" xml:id="CB142_PB-l-7">
            <seg type="hemistich">pour l&#8217;amour de V&#233;nus</seg>
            <seg type="hemistich">participons &#224; ses jeux,</seg>
          </l>
          <l n="4" xml:id="CB142_PB-l-8">
            <seg type="hemistich">pour pouvoir le rapporter</seg>
            <seg type="hemistich">aux autres demoiselles.</seg>
          </l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB142_PB-lg-3">
          <l n="1" xml:id="CB142_PB-l-9">
            <seg type="hemistich">- O ma dame bien aim&#233;e,</seg>
            <seg type="hemistich">pourquoi ainsi t&#8217;&#233;carter ?</seg>
          </l>
          <l n="2" xml:id="CB142_PB-l-10">
            <seg type="hemistich">Ne sais-tu pas, ma tr&#232;s ch&#232;re,</seg>
            <seg type="hemistich">que tu es si fort aim&#233;e ?</seg>
          </l>
          <l n="3" xml:id="CB142_PB-l-11">
            <seg type="hemistich">Si toi tu &#233;tais H&#233;l&#232;ne,</seg>
            <seg type="hemistich">je voudrais &#234;tre Paris !</seg>
          </l>
          <l n="4" xml:id="CB142_PB-l-12">
            <seg type="hemistich">Pourtant notre amour pourrait</seg>
            <seg type="hemistich">&#234;tre tout semblable au leur.</seg>
          </l>
        </lg>
        <lg type="strophe" n="IV" xml:id="CB142_PB-lg-4">
          <l n="1" xml:id="CB142_PB-l-13">
            <seg type="hemistich">Un matin, il me fallut traverser</seg>
            <seg type="hemistich">une vaste prairie,</seg>
          </l>
          <l n="2" xml:id="CB142_PB-l-14">
            <seg type="hemistich">je vis alors une jeune fille</seg>
            <seg type="hemistich">qui me salua d&#8217;un air r&#233;solu.</seg>
          </l>
          <l n="3" xml:id="CB142_PB-l-15">
            <seg type="hemistich">Elle dit : &#171; Cher ami, o&#249; souhaitez-vous aller ?</seg>
            <seg type="hemistich">Avez-vous besoin d&#8217;&#234;tre accompagn&#233; ? &#187;</seg>
          </l>
          <l n="4" xml:id="CB142_PB-l-16">
            <seg type="hemistich">Je m&#8217;inclinai &#224; ses pieds,</seg>
            <seg type="hemistich">la remerciant pour ses paroles.</seg>
          </l>
        </lg>
      </div>
    </body>
  </text>
</TEI>