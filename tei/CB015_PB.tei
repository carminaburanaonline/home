<TEI>
  <teiHeader />
  <text>
    <body>
      <div type="poem" xml:lang="french">
        <lg type="strophe" n="I" xml:id="CB015_PB-lg-1">
          <l n="1" xml:id="CB015_PB-l-1">La stabilit&#233; peut bien</l>
          <l n="2" xml:id="CB015_PB-l-2">changer de ciel, pas de c&#339;ur,</l>
          <l n="3" xml:id="CB015_PB-l-3">quand elle confirme un bon</l>
          <l n="4" xml:id="CB015_PB-l-4">propos que lui inspire</l>
          <l n="5" xml:id="CB015_PB-l-5">la fermet&#233; d&#8217;esprit, pourvu</l>
          <l n="6" xml:id="CB015_PB-l-6">qu&#8217;il en ait bien jug&#233;.</l>
          <l n="7" xml:id="CB015_PB-l-7">Car si, par le dessein</l>
          <l n="8" xml:id="CB015_PB-l-8">d&#8217;un v&#339;u trop scandaleux,</l>
          <l n="9" xml:id="CB015_PB-l-9">tu veux commettre un crime</l>
          <l n="10" xml:id="CB015_PB-l-10">par une action mauvaise,</l>
          <l n="11" xml:id="CB015_PB-l-11">la promesse ainsi faite</l>
          <l n="12" xml:id="CB015_PB-l-12">ne doit &#234;tre tenue.</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB015_PB-lg-2">
          <l n="1" xml:id="CB015_PB-l-13">Il n&#8217;&#233;tait pas stable,</l>
          <l n="2" xml:id="CB015_PB-l-14">l&#8217;escalier qui s&#8217;est &#233;croul&#233;,</l>
          <l n="3" xml:id="CB015_PB-l-15">et la base &#233;tait peu solide</l>
          <l n="4" xml:id="CB015_PB-l-16">de la maison effondr&#233;e.</l>
          <l n="5" xml:id="CB015_PB-l-17">Donc, consid&#232;re bien</l>
          <l n="6" xml:id="CB015_PB-l-18">ce que tu comptes faire :</l>
          <l n="7" xml:id="CB015_PB-l-19">tant que rien n&#8217;est conclu,</l>
          <l n="8" xml:id="CB015_PB-l-20">tiens bon pour ne pas d&#233;choir.</l>
          <l n="9" xml:id="CB015_PB-l-21">Et p&#232;se bien d&#8217;abord</l>
          <l n="10" xml:id="CB015_PB-l-22">ce &#224; quoi tu t&#8217;engages,</l>
          <l n="11" xml:id="CB015_PB-l-23">pour ne pas regretter</l>
          <l n="12" xml:id="CB015_PB-l-24">le lendemain, trop tard.</l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB015_PB-lg-3">
          <l n="1" xml:id="CB015_PB-l-25">Chose bien commenc&#233;e</l>
          <l n="2" xml:id="CB015_PB-l-26">est &#224; demi atteinte</l>
          <l n="3" xml:id="CB015_PB-l-27">pour qui n&#8217;oublie pas</l>
          <l n="4" xml:id="CB015_PB-l-28">son entreprise en cours,</l>
          <l n="5" xml:id="CB015_PB-l-29">non seulement z&#233;l&#233;</l>
          <l n="6" xml:id="CB015_PB-l-30">dans les commencements,</l>
          <l n="7" xml:id="CB015_PB-l-31">mais surtout soucieux</l>
          <l n="8" xml:id="CB015_PB-l-32">d&#8217;en finir glorieusement.</l>
          <l n="9" xml:id="CB015_PB-l-33">Car la pers&#233;v&#233;rance</l>
          <l n="10" xml:id="CB015_PB-l-34">m&#232;ne jusqu&#8217;&#224; l&#8217;issue,</l>
          <l n="11" xml:id="CB015_PB-l-35">l&#8217;incurie brouillonne</l>
          <l n="12" xml:id="CB015_PB-l-36">s&#8217;arr&#234;te &#224; l&#8217;entr&#233;e.</l>
        </lg>
        <lg type="strophe" n="IV" xml:id="CB015_PB-lg-4">
          <l n="1" xml:id="CB015_PB-l-37">La fin, non le combat,</l>
          <l n="2" xml:id="CB015_PB-l-38">est la couronne du soldat :</l>
          <l n="3" xml:id="CB015_PB-l-39">il offre un but incertain,</l>
          <l n="4" xml:id="CB015_PB-l-40">elle donne la r&#233;compense.</l>
          <l n="5" xml:id="CB015_PB-l-41">La t&#233;nacit&#233; recommande</l>
          <l n="6" xml:id="CB015_PB-l-42">ce que la fin accorde,</l>
          <l n="7" xml:id="CB015_PB-l-43">la l&#233;g&#232;ret&#233; entra&#238;ne</l>
          <l n="8" xml:id="CB015_PB-l-44">ce que redoute le combat.</l>
          <l n="9" xml:id="CB015_PB-l-45">Car un esprit concentr&#233;</l>
          <l n="10" xml:id="CB015_PB-l-46">accorde la palme</l>
          <l n="11" xml:id="CB015_PB-l-47">qu&#8217;emp&#234;che d&#8217;obtenir</l>
          <l n="12" xml:id="CB015_PB-l-48">le go&#251;t du changement.</l>
        </lg>
        <lg type="strophe" n="V" xml:id="CB015_PB-lg-5">
          <l n="1" xml:id="CB015_PB-l-49">La l&#233;g&#232;ret&#233;, comme Prot&#233;e,</l>
          <l n="2" xml:id="CB015_PB-l-50">change d&#8217;apparence,</l>
          <l n="3" xml:id="CB015_PB-l-51">c&#8217;est pourquoi elle prend</l>
          <l n="4" xml:id="CB015_PB-l-52">des formes incongrues.</l>
          <l n="5" xml:id="CB015_PB-l-53">Tandis que la constance,</l>
          <l n="6" xml:id="CB015_PB-l-54">gardant son propre aspect,</l>
          <l n="7" xml:id="CB015_PB-l-55">tient le milieu, reliant</l>
          <l n="8" xml:id="CB015_PB-l-56">l&#8217;alpha des commencements</l>
          <l n="9" xml:id="CB015_PB-l-57">et l&#8217;omega final.</l>
          <l n="10" xml:id="CB015_PB-l-58">Elle donne heureuse fin,</l>
          <l n="11" xml:id="CB015_PB-l-59">changeant, sans varier,</l>
          <l n="12" xml:id="CB015_PB-l-60">de ciel, mais non de c&#339;ur.</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>