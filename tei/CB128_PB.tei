<TEI>
  <teiHeader />
  <text>
    <body>
      <div type="poem" xml:lang="french">
        <lg type="strophe" n="I" xml:id="CB128_PB-lg-1">
          <l n="1" xml:id="CB128_PB-l-1">Un jour un naufrag&#233;</l>
          <l n="2" xml:id="CB128_PB-l-2">ramait sans port d&#8217;attache,</l>
          <l n="3" xml:id="CB128_PB-l-3">la mer &#233;tant balay&#233;e</l>
          <l n="4" xml:id="CB128_PB-l-4">par un vent venu du nord,</l>
          <l n="5" xml:id="CB128_PB-l-5">son bateau longuement </l>
          <l n="6" xml:id="CB128_PB-l-6">malmen&#233; par les flots :</l>
          <l n="7" xml:id="CB128_PB-l-7">personne sur le rivage </l>
          <l n="8" xml:id="CB128_PB-l-8">n&#8217;eut de lui compassion.</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB128_PB-lg-2">
          <l n="1" xml:id="CB128_PB-l-9">&#192; la fin deux jeunes gens</l>
          <l n="2" xml:id="CB128_PB-l-10">lui ont indiqu&#233; le port,</l>
          <l n="3" xml:id="CB128_PB-l-11">et ont redonn&#233; la vie</l>
          <l n="4" xml:id="CB128_PB-l-12">au malheureux &#233;puis&#233;.</l>
          <l n="5" xml:id="CB128_PB-l-13">Leur juste discernement</l>
          <l n="6" xml:id="CB128_PB-l-14">lui donne la direction.</l>
          <l n="7" xml:id="CB128_PB-l-15">Tout ce qui fut d&#233;voy&#233;</l>
          <l n="8" xml:id="CB128_PB-l-16">c&#232;de en ce bref retour.</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>