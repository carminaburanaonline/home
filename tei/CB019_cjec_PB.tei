  <text>
    <body>
      <div type="poem">
        <lg type="strophe" xml:id="CB019_cjec_PB-lg-1">
          <l n="1" xml:id="CB019_cjec_PB-l-1">Le bien et le mal marchent d&#8217;un pas presqu&#8217;&#233;gal,</l>
          <l n="2" xml:id="CB019_cjec_PB-l-2">le prodigue ne rach&#232;te pas le d&#233;faut de l&#8217;avare,</l>
          <l n="3" xml:id="CB019_cjec_PB-l-3">la vertu, en &#233;valuant au cas par cas,</l>
          <l n="4" rend="indent(1)" xml:id="CB019_cjec_PB-l-4">doit prudemment</l>
          <l n="5" xml:id="CB019_cjec_PB-l-5">s&#8217;assurer du juste milieu entre deux vices.</l>
        </lg>
      </div>
    </body>
  </text>
