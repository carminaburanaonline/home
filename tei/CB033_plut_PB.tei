<TEI>
  <teiHeader />
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" xml:id="CB033_plut_PB-lg-1">
          <l n="1" xml:id="CB033_plut_PB-l-1">N&#8217;aie pas honte de t&#8217;&#234;tre amus&#233;,</l>
          <l n="2" xml:id="CB033_plut_PB-l-2">mais de ne pas cesser de le faire,</l>
          <l n="3" xml:id="CB033_plut_PB-l-3">et ce que tu fis mal &#224; propos</l>
          <l n="4" xml:id="CB033_plut_PB-l-4">change-le en vie r&#233;gl&#233;e.</l>
          <l n="5" xml:id="CB033_plut_PB-l-5">Que la raison, ma&#238;tresse de m&#339;urs,</l>
          <l n="6" rend="indent(1)" xml:id="CB033_plut_PB-l-6">t&#8217;enseigne,</l>
          <l n="7" xml:id="CB033_plut_PB-l-7">pour que, digne de pr&#233;lature</l>
          <l n="8" xml:id="CB033_plut_PB-l-8">par don du bon vouloir de Dieu,</l>
          <l n="9" xml:id="CB033_plut_PB-l-9">tu remplisses ton sacerdoce</l>
          <l n="10" xml:id="CB033_plut_PB-l-10">en louange du nom du Christ.</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>