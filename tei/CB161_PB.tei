<TEI>
  <teiHeader/>
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB161_PB-lg-1">
          <l n="1" xml:id="CB161_PB-l-1">Aux portes de l&#8217;&#233;t&#233;</l>
          <l n="2" rend="indent(1)" xml:id="CB161_PB-l-2">l&#8217;Amour nous salue,</l>
          <l n="3" xml:id="CB161_PB-l-3">la terre color&#233;e de fleurs</l>
          <l n="4" rend="indent(1)" xml:id="CB161_PB-l-4">change de figure.</l>
          <l n="5" xml:id="CB161_PB-l-5">D&#233;j&#224;, porteuses d&#8217;amour,</l>
          <l n="6" xml:id="CB161_PB-l-6">les fleurs sourient au beau temps ;</l>
          <l n="7" xml:id="CB161_PB-l-7">la fleur de la tendre jeunesse</l>
          <l n="8" xml:id="CB161_PB-l-8">se fane si manque l&#8217;Amour.</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB161_PB-lg-2">
          <l n="1" xml:id="CB161_PB-l-9">Le jour du printemps est celui</l>
          <l n="2" rend="indent(1)" xml:id="CB161_PB-l-10">du commencement de tout,</l>
          <l n="3" xml:id="CB161_PB-l-11">au printemps le monde c&#233;l&#232;bre</l>
          <l n="4" rend="indent(1)" xml:id="CB161_PB-l-12">son propre anniversaire.</l>
          <l n="5" xml:id="CB161_PB-l-13">Tous les jours de cette saison</l>
          <l n="6" xml:id="CB161_PB-l-14">sont bien la f&#234;te de V&#233;nus,</l>
          <l n="7" xml:id="CB161_PB-l-15">que tous les royaumes de Zeus</l>
          <l n="8" xml:id="CB161_PB-l-16">c&#233;l&#232;brent ces solennit&#233;s !</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>