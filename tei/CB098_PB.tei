<TEI>
  <teiHeader />
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB098_PB-lg-1">
          <l n="1" xml:id="CB098_PB-l-1">Apr&#232;s la chute de Troie</l>
          <l n="2" xml:id="CB098_PB-l-2">le prince En&#233;e, selon le destin,</l>
          <l n="3" xml:id="CB098_PB-l-3">cherche en errant le sol latin.</l>
          <l n="4" xml:id="CB098_PB-l-4">Mais son errance est un bonheur,</l>
          <l n="5" xml:id="CB098_PB-l-5">puisqu&#8217;il est si bien recueilli</l>
          <l n="6" xml:id="CB098_PB-l-6">dans le royaume de Didon :</l>
          <l n="7" xml:id="CB098_PB-l-7">un h&#244;te peut avoir plus de chance,</l>
          <l n="8" xml:id="CB098_PB-l-8">on ne saurait gu&#232;re trouver</l>
          <l n="9" xml:id="CB098_PB-l-9">d&#8217;h&#244;tesse plus g&#233;n&#233;reuse.</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB098_PB-lg-2">
          <l n="1" xml:id="CB098_PB-l-10">Didon la Tyrienne accueille</l>
          <l n="2" xml:id="CB098_PB-l-11">les Troyens pouss&#233;s sur les mers,</l>
          <l n="3" xml:id="CB098_PB-l-12">&#224; eux, naufrag&#233;s si souvent,</l>
          <l n="4" xml:id="CB098_PB-l-13">elle ouvre un large h&#233;bergement.</l>
          <l n="5" xml:id="CB098_PB-l-14">Et quand elle regarde En&#233;e,</l>
          <l n="6" xml:id="CB098_PB-l-15">elle admire en suppliant</l>
          <l n="7" xml:id="CB098_PB-l-16">l&#8217;&#233;clat de son visage ardent</l>
          <l n="8" xml:id="CB098_PB-l-17">et sa chevelure ondul&#233;e.</l>
          <l n="9" xml:id="CB098_PB-l-18">Vite, elle va trouver sa s&#339;ur</l>
          <l n="10" xml:id="CB098_PB-l-19">et lui d&#233;voile sa pens&#233;e.</l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB098_PB-lg-3">
          <l n="1" xml:id="CB098_PB-l-20">&#8216;Anne, ma lumi&#232;re,</l>
          <l n="2" xml:id="CB098_PB-l-21">qu&#8217;est-il, ce prince ?</l>
          <l n="3" xml:id="CB098_PB-l-22">je ne le sais !</l>
          <l n="4" xml:id="CB098_PB-l-23">Je peine &#224; comprendre par son visage</l>
          <l n="5" xml:id="CB098_PB-l-24">quel est son honneur</l>
          <l n="6" xml:id="CB098_PB-l-25">et son humeur.</l>
          <l n="7" xml:id="CB098_PB-l-26">A mon avis,</l>
          <l n="8" xml:id="CB098_PB-l-27">je crains bien</l>
          <l n="9" xml:id="CB098_PB-l-28">qu&#8217;il ne demande &#224; m&#8217;&#233;pouser :</l>
          <l n="10" xml:id="CB098_PB-l-29">ce que mes r&#234;ves</l>
          <l n="11" xml:id="CB098_PB-l-30">pr&#233;disent en v&#233;rit&#233;.</l>
        </lg>
        <lg type="strophe" n="IV" xml:id="CB098_PB-lg-4">
          <l n="1" xml:id="CB098_PB-l-31">Vois comme il a c&#339;ur valeureux,</l>
          <l n="2" xml:id="CB098_PB-l-32">on dirait l&#8217;apparence de l&#8217;amour.</l>
          <l n="3" xml:id="CB098_PB-l-33">Douleur du sort qui a pouss&#233; ce h&#233;ros</l>
          <l n="4" xml:id="CB098_PB-l-34">parmi les &#233;cueils avides de Scylla !</l>
        </lg>
        <lg type="strophe" n="V" xml:id="CB098_PB-lg-5">
          <l n="1" xml:id="CB098_PB-l-35">Si &#224; la foi de l&#8217;hym&#233;n&#233;e</l>
          <l n="2" xml:id="CB098_PB-l-36">conclu avec Sich&#233;e</l>
          <l n="3" xml:id="CB098_PB-l-37">mon &#233;poux, je ne manquais en rien,</l>
          <l n="4" xml:id="CB098_PB-l-38">si je ne la for&#231;ais ni ne lui faisais tort,</l>
          <l n="5" xml:id="CB098_PB-l-39">&#224; cette seule faute peut-&#234;tre pourrais-je</l>
          <l n="6" xml:id="CB098_PB-l-40">me laisser aller ! &#8211; Que Jupiter</l>
          <l n="7" xml:id="CB098_PB-l-41">veuille d&#8217;abord me perdre en me jetant</l>
          <l n="8" xml:id="CB098_PB-l-42">d&#8217;un coup de foudre, honteusement,</l>
          <l n="9" xml:id="CB098_PB-l-43">du sommet de Carthage,</l>
          <l n="10" xml:id="CB098_PB-l-44">[plut&#244;t que la reine] Didon</l>
          <l n="11" xml:id="CB098_PB-l-45">se soumette &#224; de [nouveaux] ma&#238;tres !&#8217;</l>
        </lg>
        <lg type="strophe" n="VI" xml:id="CB098_PB-lg-6">
          <l n="1" xml:id="CB098_PB-l-46">Anne r&#233;pond: &#8216;Ma s&#339;ur, arr&#234;te,</l>
          <l n="2" xml:id="CB098_PB-l-47">ne r&#233;siste pas &#224; un amour flatteur.</l>
          <l n="3" xml:id="CB098_PB-l-48">Car si celui-l&#224; se lie &#224; toi, par ses hauts faits</l>
          <l n="4" xml:id="CB098_PB-l-49">comme &#233;poux il t&#8217;exaltera</l>
          <l n="5" xml:id="CB098_PB-l-50">et Carthage s&#8217;enrichira.&#8217;</l>
        </lg>
        <lg type="strophe" n="VII" xml:id="CB098_PB-lg-7">
          <l n="1" xml:id="CB098_PB-l-51">Enflamm&#233;e &#224; ces mots de sa s&#339;ur,</l>
          <l n="2" xml:id="CB098_PB-l-52">la Ph&#233;nicienne Elissa, pleine d&#8217;ardeur,</l>
          <l n="3" xml:id="CB098_PB-l-53">sous pr&#233;texte d&#8217;aller chasser,</l>
          <l n="4" xml:id="CB098_PB-l-54">un nuage de bourrasque crevant en pluie,</l>
          <l n="5" xml:id="CB098_PB-l-55">se cacha dans une grotte avec le h&#233;ros</l>
          <l n="6" xml:id="CB098_PB-l-56">et se soumit &#224; lui.</l>
        </lg>
        <lg type="strophe" n="VIII" xml:id="CB098_PB-lg-8">
          <l n="1" xml:id="CB098_PB-l-57">Le prince, en exposant</l>
          <l n="2" xml:id="CB098_PB-l-58">ses trois propositions,</l>
          <l n="3" xml:id="CB098_PB-l-59">en fait un syllogisme, elle s&#8217;y opposant</l>
          <l n="4" xml:id="CB098_PB-l-60">par de contraires motions.</l>
          <l n="5" xml:id="CB098_PB-l-61">Mais bien qu&#8217;y soient employ&#233;s</l>
          <l n="6" xml:id="CB098_PB-l-62">des arguments contraignants,</l>
          <l n="7" xml:id="CB098_PB-l-63">cependant en peu de temps</l>
          <l n="8" xml:id="CB098_PB-l-64">vient la conclusion.</l>
        </lg>
        <lg type="strophe" n="IX" xml:id="CB098_PB-lg-9">
          <l n="1" xml:id="CB098_PB-l-65">Ainsi, par leur union &#224; tous deux,</l>
          <l n="2" xml:id="CB098_PB-l-66">resplendit la r&#233;gion des cieux,</l>
          <l n="3" xml:id="CB098_PB-l-67">car aux joies d&#8217;amour</l>
          <l n="4" xml:id="CB098_PB-l-68">le monde sourit et s&#8217;illumine.</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>