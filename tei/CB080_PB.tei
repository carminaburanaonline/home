<TEI>
  <teiHeader/>
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB080_PB-lg-1">
          <l n="1" xml:id="CB080_PB-l-1">
            <seg type="hemistich">Dans la joie du beau temps</seg>
            <seg type="hemistich">la terre se renouvelle,</seg>
          </l>
          <l n="2" xml:id="CB080_PB-l-2">
            <seg type="hemistich">par l&#8217;ardeur &#224; la servir</seg>
            <seg type="hemistich">V&#233;nus se r&#233;veille.</seg>
          </l>
          <l n="3" xml:id="CB080_PB-l-3">Le ch&#339;ur des jeunes gens se r&#233;jouit,</l>
          <l n="4" xml:id="CB080_PB-l-4">
            <seg type="hemistich">les oiseaux en troupe serr&#233;e</seg>
            <seg type="hemistich">chantent en leur babil.</seg>
          </l>
        </lg>
        <lg type="refrain" xml:id="CB080_PB-lg-2">
          <head>Refrain</head>
          <l n="1" xml:id="CB080_PB-l-5">
            <seg type="hemistich">Oh que grands sont les plaisirs</seg>
            <seg type="hemistich">pour qui aime et est aim&#233;,</seg>
          </l>
          <l n="2" xml:id="CB080_PB-l-6">
            <seg type="hemistich">sans ombre d&#8217;amertume</seg>
            <seg type="hemistich">uni &#224; sa bien aim&#233;e !</seg>
          </l>
          <l n="3" xml:id="CB080_PB-l-7">Voil&#224; que reverdit</l>
          <l n="4" xml:id="CB080_PB-l-8">
            <seg type="hemistich">tout ce qui fait nos d&#233;lices,</seg>
            <seg type="hemistich">l&#8217;hiver est d&#233;racin&#233;.</seg>
          </l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB080_PB-lg-3">
          <l n="1" xml:id="CB080_PB-l-9">
            <seg type="hemistich">Les pr&#233;s sont orn&#233;s de fleurs</seg>
            <seg type="hemistich">de diverses couleurs,</seg>
          </l>
          <l n="2" xml:id="CB080_PB-l-10">
            <seg type="hemistich">et le plaisir qu&#8217;on y prend</seg>
            <seg type="hemistich">fait na&#238;tre l&#8217;amour.</seg>
          </l>
          <l n="3" xml:id="CB080_PB-l-11">Le ch&#339;ur des jeunes gens se r&#233;jouit,</l>
          <l n="4" xml:id="CB080_PB-l-12">
            <seg type="hemistich">les oiseaux en troupe serr&#233;e</seg>
            <seg type="hemistich">chantent en leur babil.</seg>
          </l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB080_PB-lg-4">
          <l n="1" xml:id="CB080_PB-l-13">Par cette vive chaleur</l>
          <l n="2" xml:id="CB080_PB-l-14">tout reprend vigueur,</l>
          <l n="3" xml:id="CB080_PB-l-15">tout ce qui d&#233;p&#233;rissait</l>
          <l n="4" xml:id="CB080_PB-l-16">sous l&#8217;hiver grincheux.</l>
          <l n="5" xml:id="CB080_PB-l-17">La terre portant verdure</l>
          <l n="6" xml:id="CB080_PB-l-18">se pare de fleurs,</l>
          <l n="7" xml:id="CB080_PB-l-19">et les bois se rev&#234;tissent</l>
          <l n="8" xml:id="CB080_PB-l-20">d&#8217;amples frondaisons.</l>
        </lg>
        <lg type="strophe" n="IV" xml:id="CB080_PB-lg-5">
          <l n="1" xml:id="CB080_PB-l-21">Le temps pr&#233;sent convient bien</l>
          <l n="2" xml:id="CB080_PB-l-22">aux services d&#8217;amours,</l>
          <l n="3" xml:id="CB080_PB-l-23">entre associ&#233;s deux &#224; deux</l>
          <l n="4" xml:id="CB080_PB-l-24">se reforment les alliances.</l>
          <l n="5" xml:id="CB080_PB-l-25">La cour des jouvencelles</l>
          <l n="6" xml:id="CB080_PB-l-26">c&#233;l&#232;bre les f&#234;tes de V&#233;nus,</l>
          <l n="7" xml:id="CB080_PB-l-27">aux &#234;tres tendres l&#8217;Amour verse</l>
          <l n="8" xml:id="CB080_PB-l-28">une boisson douce-am&#232;re.</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>