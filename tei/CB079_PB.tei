<TEI>
  <teiHeader/>
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB079_PB-lg-1">
          <l n="1" xml:id="CB079_PB-l-1">Dans l&#8217;ardeur de l&#8217;&#233;t&#233;,</l>
          <l n="2" rend="indent(1)" xml:id="CB079_PB-l-2">quand tout est en fleur,</l>
          <l n="3" xml:id="CB079_PB-l-3">j&#8217;&#233;tais confit de chaleur.</l>
          <l n="4" xml:id="CB079_PB-l-4">Sous un superbe olivier,</l>
          <l n="5" xml:id="CB079_PB-l-5">&#233;puis&#233;, tout en sueur,</l>
          <l n="6" rend="indent(1)" xml:id="CB079_PB-l-6">je me suis attard&#233;.</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB079_PB-lg-2">
          <l n="1" xml:id="CB079_PB-l-7">Cet arbre &#233;tait dans un pr&#233;</l>
          <l n="2" xml:id="CB079_PB-l-8">couvert de fleurs, pleins d&#8217;agr&#233;ments</l>
          <l n="3" xml:id="CB079_PB-l-9">par son site, l&#8217;herbe et la source,</l>
          <l n="4" xml:id="CB079_PB-l-10">et par l&#8217;ombre, o&#249; soufflait la brise.</l>
          <l n="5" xml:id="CB079_PB-l-11">Platon n&#8217;aurait pu d&#233;crire</l>
          <l n="6" rend="indent(1)" xml:id="CB079_PB-l-12">de lieu plus charmant.</l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB079_PB-lg-3">
          <l n="1" xml:id="CB079_PB-l-13">S&#8217;y trouve un ru au cours rapide,</l>
          <l n="2" xml:id="CB079_PB-l-14">et le chant du rossignol,</l>
          <l n="3" xml:id="CB079_PB-l-15">et les chansons des na&#239;ades,</l>
          <l n="4" xml:id="CB079_PB-l-16">c&#8217;est l&#224; presqu&#8217;un paradis !</l>
          <l n="5" xml:id="CB079_PB-l-17">Il n&#8217;est pas, je le sais bien,</l>
          <l n="6" rend="indent(1)" xml:id="CB079_PB-l-18">d&#8217;endroit plus plaisant.</l>
        </lg>
        <lg type="strophe" n="IV" xml:id="CB079_PB-lg-4">
          <l n="1" xml:id="CB079_PB-l-19">L&#224;, tandis que je me complais</l>
          <l n="2" xml:id="CB079_PB-l-20">&#224; prendre plaisamment mon temps,</l>
          <l n="3" xml:id="CB079_PB-l-21">&#224; rafra&#238;chir la canicule,</l>
          <l n="4" xml:id="CB079_PB-l-22">j&#8217;aper&#231;ois une pastourelle</l>
          <l n="5" xml:id="CB079_PB-l-23">d&#8217;une beaut&#233; exceptionnelle,</l>
          <l n="6" rend="indent(1)" xml:id="CB079_PB-l-24">qui cueillait des m&#251;res.</l>
        </lg>
        <lg type="strophe" n="V" xml:id="CB079_PB-lg-5">
          <l n="1" xml:id="CB079_PB-l-25">La voyant, je tombe amoureux</l>
          <l n="2" xml:id="CB079_PB-l-26">(c&#8217;est la faute &#224; V&#233;nus, je crois).</l>
          <l n="3" xml:id="CB079_PB-l-27">&#171; Viens, je ne suis pas un brigand,</l>
          <l n="4" xml:id="CB079_PB-l-28">je ne prends rien, n&#8217;ab&#238;me rien,</l>
          <l n="5" xml:id="CB079_PB-l-29">je me donne &#224; toi corps et biens,</l>
          <l n="6" rend="indent(1)" xml:id="CB079_PB-l-30">toi qui es la plus belle ! &#187;</l>
        </lg>
        <lg type="strophe" n="VI" xml:id="CB079_PB-lg-6">
          <l n="1" xml:id="CB079_PB-l-31">Elle me r&#233;pondit tout net :</l>
          <l n="2" xml:id="CB079_PB-l-32">&#171; Je ne connais les jeux des hommes.</l>
          <l n="3" xml:id="CB079_PB-l-33">J&#8217;ai des parents tr&#232;s s&#233;v&#232;res,</l>
          <l n="4" xml:id="CB079_PB-l-34">et de plus ma vieille m&#232;re</l>
          <l n="5" xml:id="CB079_PB-l-35">se f&#226;chera pour un rien.</l>
          <l n="6" rend="indent(1)" xml:id="CB079_PB-l-36">D&#233;sol&#233;e pour l&#8217;instant. &#187;</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>