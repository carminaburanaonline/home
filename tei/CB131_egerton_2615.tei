  <text>
    <body>
      <div type="poem" met="4x6pp 4x8p 2x(8pp 7p)">
        <lg type="strophe" met="6pp/6pp/6pp/6pp/8p/8p/8p/8p/8pp/7p/8pp/7p" rhyme="a/a/a/a/b/b/c/c/d/e/d/e" xml:id="CB131_egerton_2615-lg-1">
          <l n="1" xml:id="CB131_egerton_2615-l-1">
            <w>Dic</w>
            <pc resp="#editor">,</pc>
            <w>Christi</w>
            <w>veritas</w>
            <pc resp="#editor">,</pc>
          </l>
          <l n="2" xml:id="CB131_egerton_2615-l-2">
            <w>dic</w>
            <pc resp="#editor">,</pc>
            <app type="text">
              <lem wit="cod.">
                <w>rara</w>
                <w>caritas</w>
              </lem>
              <rdg wit="HSB V T"><w>cara</w><w>raritas</w></rdg>
            </app>
          </l>
          <l n="3" xml:id="CB131_egerton_2615-l-3">
            <w>dic</w>
            <pc resp="#editor">,</pc>
            <app type="text">
              <lem wit="cod.">
                <w>cara</w>
                <w>raritas</w>
              </lem>
              <rdg wit="HSB V T"><w>rara</w><w>caritas</w></rdg>
            </app>
            <pc resp="#editor">,</pc>
          </l>
          <l n="4" xml:id="CB131_egerton_2615-l-4">
            <w>ubi</w>
            <w>nunc</w>
            <w>habitas</w>
            <pc resp="#editor">?</pc>
          </l>
          <l n="5" xml:id="CB131_egerton_2615-l-5">
            <w>Aut</w>
            <w>in</w>
            <w>valle</w>
            <w>visionis</w>
            <pc resp="#editor">?</pc>
          </l>
          <l n="6" xml:id="CB131_egerton_2615-l-6">
            <w>aut</w>
            <w>in</w>
            <app type="text">
              <lem>
                <w>trono</w>
              </lem>
              <note>corr. ex <w>antro</w> cod.</note>
            </app>
            <w>Pharaonis</w>
            <pc resp="#editor">?</pc>
          </l>
          <l n="7" xml:id="CB131_egerton_2615-l-7">
            <w>aut</w>
            <w>in</w>
            <w>alto</w>
            <w>cum</w>
            <w>Nerone</w>
            <pc>&#183;</pc>
            <pc resp="#editor">?</pc>
          </l>
          <l n="8" xml:id="CB131_egerton_2615-l-8">
            <w>aut</w>
            <w>in</w>
            <w>antro</w>
            <w>cum</w>
            <w>Theone</w>
            <pc resp="#editor">?</pc>
          </l>
          <l n="9" xml:id="CB131_egerton_2615-l-9">
            <w>Vel</w>
            <w>in</w>
            <app type="text">
              <lem wit="HSB">
                <w>fiscella</w>
              </lem>
              <rdg wit="cod."><w>ficella</w></rdg>
            </app>
            <pc resp="#editor" pre="true">[</pc>
            <app type="text">
              <lem>
                <w>scirpea</w>
              </lem>
              <note>post c- lac. cod.</note>
            </app>
          </l>
          <l n="10" xml:id="CB131_egerton_2615-l-10">
            <app type="text">
              <lem>
                <w>cum</w>
              </lem>
              <note>lac. cod.</note>
            </app>
            <pc resp="#editor">]</pc>
            <w>Moyse</w>
            <w>plorante</w>
            <pc>&#183;</pc>
            <pc resp="#editor">?</pc>
          </l>
          <l n="11" xml:id="CB131_egerton_2615-l-11">
            <w>Vel</w>
            <w>in</w>
            <w>domo</w>
            <w>Romulea</w>
            <pc resp="#editor">,</pc>
          </l>
          <l n="12" xml:id="CB131_egerton_2615-l-12">
            <w>cum</w>
            <w>bulla</w>
            <w>fulminante</w>
            <pc>&#183;</pc>
            <pc resp="#editor">?</pc>
          </l>
        </lg>
      </div>
    </body>
  </text>
