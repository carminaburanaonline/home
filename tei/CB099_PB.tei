<TEI>
  <teiHeader/>
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB099_PB-lg-1">
          <l n="1" xml:id="CB099_PB-l-1">
            <seg type="hemistich">L&#8217;insoucieux jugement</seg>
            <seg type="hemistich">de l&#8217;orgueilleux Paris</seg>
          </l>
          <l n="2" xml:id="CB099_PB-l-2">
            <seg type="hemistich">et la beaut&#233; d&#8217;H&#233;l&#232;ne,</seg>
            <seg type="hemistich">ador&#233;e &#224; l&#8217;exc&#232;s,</seg>
          </l>
          <l n="3" xml:id="CB099_PB-l-3">
            <seg type="hemistich">furent la fin de Troie</seg>
            <seg type="hemistich">et la chute d&#8217;Ilion.</seg>
          </l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB099_PB-lg-2">
          <l n="1" xml:id="CB099_PB-l-4">
            <seg type="hemistich">De quoi d&#233;sesp&#233;r&#233;,</seg>
            <seg type="hemistich">En&#233;e prend la fuite,</seg>
          </l>
          <l n="2" xml:id="CB099_PB-l-5">
            <seg type="hemistich">monte sur les bateaux</seg>
            <seg type="hemistich">au p&#233;ril de la mer,</seg>
          </l>
          <l n="3" xml:id="CB099_PB-l-6">
            <seg type="hemistich">et s&#8217;en vient &#224; Carthage,</seg>
            <seg type="hemistich">l&#224; o&#249; Didon est reine.</seg>
          </l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB099_PB-lg-3">
          <l n="1" xml:id="CB099_PB-l-7">
            <seg type="hemistich">Didon la Sidonienne</seg>
            <seg type="hemistich">l&#8217;accueille en son royaume,</seg>
          </l>
          <l n="2" xml:id="CB099_PB-l-8">
            <seg type="hemistich">et bless&#233;e d&#8217;amour</seg>
            <seg type="hemistich">plus qu&#8217;il ne conviendrait,</seg>
          </l>
          <l n="3" xml:id="CB099_PB-l-9">
            <seg type="hemistich">pour se lier &#224; lui</seg>
            <seg type="hemistich">ne souffre aucun d&#233;lai.</seg>
          </l>
        </lg>
        <lg type="strophe" n="IV" xml:id="CB099_PB-lg-4">
          <l n="1" xml:id="CB099_PB-l-10">
            <seg type="hemistich">Ainsi, sauvage amour,</seg>
            <seg type="hemistich">tu soumets toutes choses,</seg>
          </l>
          <l n="2" xml:id="CB099_PB-l-11">
            <seg type="hemistich">ainsi &#224; tes pouvoirs</seg>
            <seg type="hemistich">rien ne peut r&#233;sister,</seg>
          </l>
          <l n="3" xml:id="CB099_PB-l-12">
            <seg type="hemistich">et la mort suit de pr&#232;s</seg>
            <seg type="hemistich">les joies que tu donnes.</seg>
          </l>
        </lg>
        <lg type="strophe" n="V" xml:id="CB099_PB-lg-5">
          <l n="1" xml:id="CB099_PB-l-13">
            <seg type="hemistich">Car &#201;n&#233;e re&#231;oit</seg>
            <seg type="hemistich">de violents reproches,</seg>
          </l>
          <l n="2" xml:id="CB099_PB-l-14">
            <seg type="hemistich">et l&#8217;ordre de partir</seg>
            <seg type="hemistich">de l&#224; pour l&#8217;Italie.</seg>
          </l>
          <l n="3" xml:id="CB099_PB-l-15">
            <seg type="hemistich">Son amante Didon</seg>
            <seg type="hemistich">en est boulevers&#233;e.</seg>
          </l>
        </lg>
        <lg type="strophe" n="VI" xml:id="CB099_PB-lg-6">
          <l n="1" xml:id="CB099_PB-l-16">
            <seg type="hemistich">&#171; En&#233;e mon seigneur,</seg>
            <seg type="hemistich">qu&#8217;est-ce donc que j&#8217;entends ?</seg>
          </l>
          <l n="2" xml:id="CB099_PB-l-17">
            <seg type="hemistich">De la pauvre Didon</seg>
            <seg type="hemistich">tu vas causer la perte ?</seg>
          </l>
          <l n="3" xml:id="CB099_PB-l-18">
            <seg type="hemistich">Quelle &#226;pre r&#233;compense</seg>
            <seg type="hemistich">pour ce que tu me dois !</seg>
          </l>
        </lg>
        <lg type="strophe" n="VII" xml:id="CB099_PB-lg-7">
          <l n="1" xml:id="CB099_PB-l-19">
            <seg type="hemistich">Je t&#8217;ai recueilli nu,</seg>
            <seg type="hemistich">et de tout d&#233;pourvu !</seg>
            <seg type="hemistich"/>
          </l>
          <l n="2" xml:id="CB099_PB-l-20">
            <seg type="hemistich">Ainsi notre union</seg>
            <seg type="hemistich">a offens&#233; les dieux.</seg>
          </l>
          <l n="3" xml:id="CB099_PB-l-21">
            <seg type="hemistich">Je ne sais plus que faire,</seg>
            <seg type="hemistich">ne reste que la mort.</seg>
          </l>
        </lg>
        <lg type="strophe" n="VIII" xml:id="CB099_PB-lg-8">
          <l n="1" xml:id="CB099_PB-l-22">
            <seg type="hemistich">Qu&#8217;entends-je dire, Anna,</seg>
            <seg type="hemistich">&#244; ma s&#339;ur bien-aim&#233;e ?</seg>
          </l>
          <l n="2" xml:id="CB099_PB-l-23">
            <seg type="hemistich">D&#233;j&#224; glissent les voiles</seg>
            <seg type="hemistich">au fond de l&#8217;horizon ! </seg>
          </l>
          <l n="3" xml:id="CB099_PB-l-24">
            <seg type="hemistich">Brise ma pauvre vie,</seg>
            <seg type="hemistich">&#244; mort trop douloureuse ! &#187; </seg>
          </l>
        </lg>
        <lg type="strophe" n="IX" xml:id="CB099_PB-lg-9">
          <l n="1" xml:id="CB099_PB-l-25">
            <seg type="hemistich">Et la noble Didon</seg>
            <seg type="hemistich">demeure abandonn&#233;e,</seg>
          </l>
          <l n="2" xml:id="CB099_PB-l-26">
            <seg type="hemistich">le but est d&#233;sormais</seg>
            <seg type="hemistich">le lit de Lavinie.</seg>
          </l>
          <l n="3" xml:id="CB099_PB-l-27">
            <seg type="hemistich">Pour chercher la pr&#234;tresse,</seg>
            <seg type="hemistich">vite Anne est &#233;cart&#233;e.</seg>
          </l>
        </lg>
        <lg type="strophe" n="X" xml:id="CB099_PB-lg-10">
          <l n="1" xml:id="CB099_PB-l-28">
            <seg type="hemistich">&#171; &#201;p&#233;e du perfide,</seg>
            <seg type="hemistich">avec toute ta force,</seg>
          </l>
          <l n="2" xml:id="CB099_PB-l-29">
            <seg type="hemistich">mets fin &#224; mes soupirs</seg>
            <seg type="hemistich">en transper&#231;ant mon corps ! &#187;</seg>
          </l>
          <l n="3" xml:id="CB099_PB-l-30">Ah malheureux amants, redoutez pareil sort !</l>
        </lg>
        <lg type="strophe" n="XI" xml:id="CB099_PB-lg-11">
          <l n="1" xml:id="CB099_PB-l-31">
            <seg type="hemistich">D&#233;j&#224; en Italie,</seg>
            <seg type="hemistich">quand &#201;n&#233;e entend dire</seg>
          </l>
          <l n="2" xml:id="CB099_PB-l-32">
            <seg type="hemistich">comment Didon mourut</seg>
            <seg type="hemistich">si mis&#233;rablement,</seg>
          </l>
          <l n="3" xml:id="CB099_PB-l-33">
            <seg type="hemistich">et que sa compagnie</seg>
            <seg type="hemistich">a d&#251; se disperser,</seg>
          </l>
        </lg>
        <lg type="strophe" n="XII" xml:id="CB099_PB-lg-12">
          <l n="1" xml:id="CB099_PB-l-34">
            <seg type="hemistich">lui qui a sans faiblir</seg>
            <seg type="hemistich">support&#233; tant de drames </seg>
          </l>
          <l n="2" xml:id="CB099_PB-l-35">
            <seg type="hemistich">arrache ses cheveux</seg>
            <seg type="hemistich">et ses habits de soie,</seg>
          </l>
          <l n="3" xml:id="CB099_PB-l-36">
            <seg type="hemistich">puis se met &#224; clamer</seg>
            <seg type="hemistich">d&#8217;une voix d&#233;chirante :</seg>
          </l>
        </lg>
        <lg type="strophe" n="XIII" xml:id="CB099_PB-lg-13">
          <l n="1" xml:id="CB099_PB-l-37">
            <seg type="hemistich">&#171; Je ne l&#8217;aurais pas cru,</seg>
            <seg type="hemistich">Didon, ce que j&#8217;entends :</seg>
          </l>
          <l n="2" xml:id="CB099_PB-l-38">
            <seg type="hemistich">que tu te sois tu&#233;e</seg>
            <seg type="hemistich">avec ma propre &#233;p&#233;e,</seg>
          </l>
          <l n="3" xml:id="CB099_PB-l-39">
            <seg type="hemistich">pour que ce soit bien moi</seg>
            <seg type="hemistich">l&#8217;occasion de ta mort.</seg>
          </l>
        </lg>
        <lg type="strophe" n="XIV" xml:id="CB099_PB-lg-14">
          <l n="1" xml:id="CB099_PB-l-40">
            <seg type="hemistich">Tu avais r&#233;par&#233;</seg>
            <seg type="hemistich">mes nefs d&#233;sempar&#233;es,</seg>
          </l>
          <l n="2" xml:id="CB099_PB-l-41">
            <seg type="hemistich">et tu m&#8217;avais re&#231;u mieux</seg>
            <seg type="hemistich">que comme un simple h&#244;te,</seg>
          </l>
          <l n="3" xml:id="CB099_PB-l-42">
            <seg type="hemistich">tu m&#8217;avais &#233;lev&#233;</seg>
            <seg type="hemistich">sur le tr&#244;ne royal.</seg>
          </l>
        </lg>
        <lg type="strophe" n="XV" xml:id="CB099_PB-lg-15">
          <l n="1" xml:id="CB099_PB-l-43">
            <seg type="hemistich">Tu as &#233;t&#233; pour moi</seg>
            <seg type="hemistich">ce qui sauve la vie,</seg>
          </l>
          <l n="2" xml:id="CB099_PB-l-44">
            <seg type="hemistich">et moi je suis pour toi</seg>
            <seg type="hemistich">l&#8217;issue de la mort.</seg>
          </l>
          <l n="3" xml:id="CB099_PB-l-45">
            <seg type="hemistich">Quel &#233;change est-ce l&#224;,</seg>
            <seg type="hemistich">et qu&#8217;il est d&#233;testable !</seg>
          </l>
        </lg>
        <lg type="strophe" n="XVI" xml:id="CB099_PB-lg-16">
          <l n="1" xml:id="CB099_PB-l-46">
            <seg type="hemistich">Alors que j&#8217;&#233;tais pauvre</seg>
            <seg type="hemistich">et loin de ma patrie,</seg>
          </l>
          <l n="2" xml:id="CB099_PB-l-47">
            <seg type="hemistich">tu m&#8217;avais par faveur</seg>
            <seg type="hemistich">donn&#233; la pr&#233;f&#233;rence</seg>
          </l>
          <l n="3" xml:id="CB099_PB-l-48">
            <seg type="hemistich">sur le noble Hiarbas,</seg>
            <seg type="hemistich">terreur de la Lybie.</seg>
          </l>
        </lg>
        <lg type="strophe" n="XVII" xml:id="CB099_PB-lg-17">
          <l n="1" xml:id="CB099_PB-l-49">
            <seg type="hemistich">Si souvent me revient</seg>
            <seg type="hemistich">ton lumineux visage,</seg>
          </l>
          <l n="2" xml:id="CB099_PB-l-50">
            <seg type="hemistich">ton souffle parfum&#233;,</seg>
            <seg type="hemistich">ta douce chevelure,</seg>
          </l>
          <l n="3" xml:id="CB099_PB-l-51">
            <seg type="hemistich">le merveilleux aspect</seg>
            <seg type="hemistich">de chacun de tes membres !</seg>
          </l>
        </lg>
        <lg type="strophe" n="XVIII" xml:id="CB099_PB-lg-18">
          <l n="1" xml:id="CB099_PB-l-52">
            <seg type="hemistich">Pour eux, totalement</seg>
            <seg type="hemistich">m&#8217;&#233;taient sortis du c&#339;ur</seg>
          </l>
          <l n="2" xml:id="CB099_PB-l-53">
            <seg type="hemistich">les maux de ma patrie,</seg>
            <seg type="hemistich">les lamentations</seg>
          </l>
          <l n="3" xml:id="CB099_PB-l-54">
            <seg type="hemistich">de mon peuple, et la mort</seg>
            <seg type="hemistich">de mes &#233;pouse et p&#232;re. </seg>
          </l>
        </lg>
        <lg type="strophe" n="XIX" xml:id="CB099_PB-lg-19">
          <l n="1" xml:id="CB099_PB-l-55">
            <seg type="hemistich">Il n&#8217;est pas toujours bon</seg>
            <seg type="hemistich">de s&#8217;en remettre aux dieux,</seg>
          </l>
          <l n="2" xml:id="CB099_PB-l-56">
            <seg type="hemistich">ni d&#8217;accepter de faire</seg>
            <seg type="hemistich">tout ce qu&#8217;ils vous indiquent :</seg>
          </l>
          <l n="3" xml:id="CB099_PB-l-57">
            <seg type="hemistich">car ils m&#8217;avaient pouss&#233;,</seg>
            <seg type="hemistich">moi, &#224; t&#8217;abandonner.</seg>
          </l>
        </lg>
        <lg type="strophe" n="XX" xml:id="CB099_PB-lg-20">
          <l n="1" xml:id="CB099_PB-l-58">
            <seg type="hemistich">Didon, puisses-tu jouir</seg>
            <seg type="hemistich">des champs &#233;lys&#233;ens,</seg>
          </l>
          <l n="2" xml:id="CB099_PB-l-59">
            <seg type="hemistich">et parmi leurs plaisirs,</seg>
            <seg type="hemistich">entendre [enfin] &#201;n&#233;e</seg>
          </l>
          <l n="3" xml:id="CB099_PB-l-60">
            <seg type="hemistich">pour les bienfaits re&#231;us</seg>
            <seg type="hemistich">te rendre pleine gr&#226;ce ! &#187;</seg>
          </l>
        </lg>
      </div>
    </body>
  </text>
</TEI>