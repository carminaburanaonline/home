<TEI>
  <teiHeader/>
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB180_PB-lg-1">
          <l n="1" xml:id="CB180_PB-l-1">O ma tellement ch&#233;rie,</l>
          <l n="2" xml:id="CB180_PB-l-2">lis d&#8217;un visage serein</l>
          <l n="3" xml:id="CB180_PB-l-3">et bien attentivement</l>
          <l n="4" xml:id="CB180_PB-l-4">ce que ma lettre te dit.</l>
        </lg>
        <lg type="refrain" xml:id="CB180_PB-lg-2">
          <head>Refrain</head>
          <l n="1" xml:id="CB180_PB-l-5">Dis-lui, mon chant, dis-lui, va,</l>
          <l n="2" xml:id="CB180_PB-l-6">mais mon amie ne vient pas !</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB180_PB-lg-3">
          <l n="1" xml:id="CB180_PB-l-7">&#171; Quelle est donc cette enfant,</l>
          <l n="2" xml:id="CB180_PB-l-8">disais-je, au teint &#233;blouissant,</l>
          <l n="3" xml:id="CB180_PB-l-9">au visage o&#249; la blancheur</l>
          <l n="4" xml:id="CB180_PB-l-10">brille li&#233;e &#224; la rougeur?</l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB180_PB-lg-4">
          <l n="1" xml:id="CB180_PB-l-11">Ton visage montre bien</l>
          <l n="2" xml:id="CB180_PB-l-12">combien ta noblesse est grande,</l>
          <l n="3" xml:id="CB180_PB-l-13">qui m&#233;lange dans ton sein</l>
          <l n="4" xml:id="CB180_PB-l-14">le lait blanc et le rouge sang ...</l>
        </lg>
        <lg type="strophe" n="IV" xml:id="CB180_PB-lg-5">
          <l n="1" xml:id="CB180_PB-l-15">Quelle est donc cette enfant</l>
          <l n="2" xml:id="CB180_PB-l-16">si douce et si charmante ?</l>
          <l n="3" xml:id="CB180_PB-l-17">Je br&#251;le d&#8217;amour pour elle,</l>
          <l n="4" xml:id="CB180_PB-l-18">tant que j&#8217;en survis &#224; peine !</l>
        </lg>
        <lg type="strophe" n="V" xml:id="CB180_PB-lg-6">
          <l n="1" xml:id="CB180_PB-l-19">A cause de ta beaut&#233;</l>
          <l n="2" xml:id="CB180_PB-l-20">mon c&#339;ur est assi&#233;g&#233;</l>
          <l n="3" xml:id="CB180_PB-l-21">d&#8217;une foule de soupirs</l>
          <l n="4" xml:id="CB180_PB-l-22">qui trop fort me font souffrir.</l>
        </lg>
        <lg type="strophe" n="VI" xml:id="CB180_PB-lg-7">
          <l n="1" xml:id="CB180_PB-l-23">Tes yeux sont aussi brillants</l>
          <l n="2" xml:id="CB180_PB-l-24">que les rayons du soleil,</l>
          <l n="3" xml:id="CB180_PB-l-25">que la splendeur de l&#8217;&#233;clair</l>
          <l n="4" xml:id="CB180_PB-l-26">illuminant les t&#233;n&#232;bres. &#187;</l>
        </lg>
        <lg type="strophe" n="VII" xml:id="CB180_PB-lg-8">
          <l n="1" xml:id="CB180_PB-l-27">Si Dieu, si les dieux m&#8217;avaient donn&#233;</l>
          <l n="2" xml:id="CB180_PB-l-28">d&#8217;accomplir mon intention :</l>
          <l n="3" xml:id="CB180_PB-l-29">que j&#8217;aie pu lib&#233;rer</l>
          <l n="4" xml:id="CB180_PB-l-30">sa virginale prison...</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>