            <w>prebendas</w>
            <pc resp="#editor">,</pc>
          </l>
          <l n="2" xml:id="CB131_egerton_274-l-26">
            <app type="text">
              frustra vitam pretendas cod.&#61533; vitam frustra commendas HS V T
