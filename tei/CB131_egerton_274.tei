        <lg type="strophe" n="II" met="6p/7p/6p/7p/7pp/4pp/4pp/7p/7pp/7p/5pp/8p" rhyme="a/a/a/a/b/b/b/a/b/a/b/a" xml:id="CB131_egerton_274-lg-2">
