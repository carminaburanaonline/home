<TEI>
  <teiHeader/>
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB021_plut_PB-lg-1">
          <l n="1" xml:id="CB021_plut_PB-l-1">V&#233;rit&#233; des v&#233;rit&#233;s,</l>
          <l n="2" xml:id="CB021_plut_PB-l-2">voie, vie et v&#233;rit&#233;,</l>
          <l n="3" xml:id="CB021_plut_PB-l-3">par tes chemins de v&#233;rit&#233;</l>
          <l n="4" xml:id="CB021_plut_PB-l-4">tu &#233;limines le p&#233;ch&#233; !</l>
          <l n="5" xml:id="CB021_plut_PB-l-5">La foi, l&#8217;espoir, la charit&#233;</l>
          <l n="6" xml:id="CB021_plut_PB-l-6">te proclament Verbe incarn&#233;,</l>
          <l n="7" xml:id="CB021_plut_PB-l-7">tu restaures pour le coupable</l>
          <l n="8" xml:id="CB021_plut_PB-l-8">l&#8217;&#233;tat de la paix initiale,</l>
          <l n="9" xml:id="CB021_plut_PB-l-9">apr&#232;s les d&#233;lices charnelles</l>
          <l n="10" xml:id="CB021_plut_PB-l-10">tu donnes l&#8217;&#233;tat de gr&#226;ce</l>
          <l n="11" xml:id="CB021_plut_PB-l-11">pour faire un bienheureux.</l>
          <l n="12" xml:id="CB021_plut_PB-l-12">Oh quel &#233;tonnant pouvoir,</l>
          <l n="13" xml:id="CB021_plut_PB-l-13">quelle voix de prince royal,</l>
          <l n="14" xml:id="CB021_plut_PB-l-14">quand tu ordonnes &#224; l&#8217;infirme :</l>
          <l n="15" xml:id="CB021_plut_PB-l-15">&#171; Debout, prends ton grabat et marche! &#187;</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB021_plut_PB-lg-2">
          <l n="1" xml:id="CB021_plut_PB-l-16">La faute d&#8217;Adam a enferm&#233;</l>
          <l n="2" xml:id="CB021_plut_PB-l-17">le monde sous le p&#233;ch&#233;,</l>
          <l n="3" xml:id="CB021_plut_PB-l-18">quand trop port&#233; vers l&#8217;interdit</l>
          <l n="4" xml:id="CB021_plut_PB-l-19">&#224; l&#8217;ordre il n&#8217;a pas ob&#233;i.</l>
          <l n="5" xml:id="CB021_plut_PB-l-20">Loin de cet &#233;tat bienheureux,</l>
          <l n="6" xml:id="CB021_plut_PB-l-21">il nous a livr&#233;s &#224; la mort.</l>
          <l n="7" xml:id="CB021_plut_PB-l-22">Depuis cette bouch&#233;e venimeuse</l>
          <l n="8" xml:id="CB021_plut_PB-l-23">le poison colle &#224; nos palais,</l>
          <l n="9" xml:id="CB021_plut_PB-l-24">par cette faute bien f&#226;cheuse</l>
          <l n="10" xml:id="CB021_plut_PB-l-25">elle se transforme en d&#233;faut</l>
          <l n="11" xml:id="CB021_plut_PB-l-26">pour chacun de nous lorsqu&#8217;il na&#238;t.</l>
          <l n="12" xml:id="CB021_plut_PB-l-27">L&#8217;am&#232;re coupe de la mort</l>
          <l n="13" xml:id="CB021_plut_PB-l-28">se d&#233;verse sur notre si&#232;cle  :</l>
          <l n="14" xml:id="CB021_plut_PB-l-29">on n&#8217;y peut rien boire de pur</l>
          <l n="15" xml:id="CB021_plut_PB-l-30">de ce vase contamin&#233;.</l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB021_plut_PB-lg-3">
          <l n="1" xml:id="CB021_plut_PB-l-31">L&#8217;esprit de v&#233;rit&#233;,</l>
          <l n="2" xml:id="CB021_plut_PB-l-32">l&#8217;esprit de bon conseil</l>
          <l n="3" xml:id="CB021_plut_PB-l-33">n&#8217;applique pas maintenant</l>
          <l n="4" xml:id="CB021_plut_PB-l-34">la punition due aux p&#233;ch&#233;s,</l>
          <l n="5" xml:id="CB021_plut_PB-l-35">pour qu&#8217;une puret&#233; craintive,</l>
          <l n="6" xml:id="CB021_plut_PB-l-36">celle des fils respectueux,</l>
          <l n="7" xml:id="CB021_plut_PB-l-37">r&#233;prime chez les pr&#233;lats</l>
          <l n="8" xml:id="CB021_plut_PB-l-38">l&#8217;antique levain du mal.</l>
          <l n="9" xml:id="CB021_plut_PB-l-39">Mais quand l&#8217;&#201;poux viendra,</l>
          <l n="10" rend="indent(1)" xml:id="CB021_plut_PB-l-40">il trouvera</l>
          <l n="11" xml:id="CB021_plut_PB-l-41">ce qu&#8217;il va faire aux ingrats.</l>
          <l n="12" xml:id="CB021_plut_PB-l-42">Pour qui il la fait attendre,</l>
          <l n="13" xml:id="CB021_plut_PB-l-43">il n&#8217;a pas supprim&#233; la peine,</l>
          <l n="14" xml:id="CB021_plut_PB-l-44">mais la graisse d&#8217;iniquit&#233;</l>
          <l n="15" xml:id="CB021_plut_PB-l-45">est en train de pr&#233;parer son &#226;me</l>
          <l n="16" xml:id="CB021_plut_PB-l-46">pour le futur sacrifice.</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>