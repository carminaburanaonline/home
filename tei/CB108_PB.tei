<TEI>
  <teiHeader/>
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB108_PB-lg-1">
          <l n="1" xml:id="CB108_PB-l-1">En suspens sur le fl&#233;au</l>
          <l n="2" xml:id="CB108_PB-l-2">d&#8217;une balance h&#233;sitante,</l>
          <l n="3" xml:id="CB108_PB-l-3">mon esprit reste flottant</l>
          <l n="4" xml:id="CB108_PB-l-4">et bouillonnant.</l>
          <l n="5" xml:id="CB108_PB-l-5">Je suis d&#233;chir&#233; :</l>
          <l n="6" xml:id="CB108_PB-l-6">car la Raison</l>
          <l n="7" xml:id="CB108_PB-l-7">combat l&#8217;Amour,</l>
          <l n="8" xml:id="CB108_PB-l-8">j&#8217;en suis tortur&#233;.</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB108_PB-lg-2">
          <l n="1" xml:id="CB108_PB-l-9">Sur la balance je soup&#233;se</l>
          <l n="2" xml:id="CB108_PB-l-10">ce qui vaut mieux,</l>
          <l n="3" xml:id="CB108_PB-l-11">mon esprit douteux</l>
          <l n="4" xml:id="CB108_PB-l-12">avec lui-m&#233;me d&#233;lib&#233;re.</l>
          <l n="5" xml:id="CB108_PB-l-13">Par moments je me rem&#233;more</l>
          <l n="6" xml:id="CB108_PB-l-14">les plaisirs d'amour heureux,</l>
          <l n="7" xml:id="CB108_PB-l-15">les baisers que me donne</l>
          <l n="8" xml:id="CB108_PB-l-16">ma petite Fleur,</l>
          <l n="9" xml:id="CB108_PB-l-17">son rire, ses l&#233;vres, ses traits,</l>
          <l n="10" xml:id="CB108_PB-l-18">son front, son nez, et ses cheveux...</l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB108_PB-lg-3">
          <l n="1" xml:id="CB108_PB-l-19">Comme sur l'arbre la feuille tremblante,</l>
          <l n="2" xml:id="CB108_PB-l-20">comme sur la mer</l>
          <l n="3" xml:id="CB108_PB-l-21">la barque l&#233;g&#232;re</l>
          <l n="4" xml:id="CB108_PB-l-22">lorsque lui manque</l>
          <l n="5" xml:id="CB108_PB-l-23">l'appui de son ancre</l>
          <l n="6" xml:id="CB108_PB-l-24">se fait ballotter par un vent contraire,</l>
          <l n="7" xml:id="CB108_PB-l-25">ainsi m'assaillent,</l>
          <l n="8" xml:id="CB108_PB-l-26">ainsi me tiraillent</l>
          <l n="9" xml:id="CB108_PB-l-27">en un tourbillon d'ind&#233;cision,</l>
          <l n="10" xml:id="CB108_PB-l-28">par ici l'amour, par l&#224; la raison.</l>
        </lg>
        <lg type="strophe" n="IV" xml:id="CB108_PB-lg-4">
          <l n="1" xml:id="CB108_PB-l-29">J'en d&#233;p&#233;ris !</l>
          <l n="2" xml:id="CB108_PB-l-30">Je vois la cause de mon souci,</l>
          <l n="3" xml:id="CB108_PB-l-31">je vois, je sais, et je me perds !</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>