<TEI>
  <teiHeader />
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB031_PB-lg-1">
          <l n="1" rend="indent(1)" xml:id="CB031_PB-l-1">Je m&#8217;&#233;tais soumis</l>
          <l n="2" rend="indent(1)" xml:id="CB031_PB-l-2">&#224; la dure loi</l>
          <l n="3" rend="indent(1)" xml:id="CB031_PB-l-3">d&#8217;une vie perdue,</l>
          <l n="4" rend="indent(1)" xml:id="CB031_PB-l-4">scandaleusement</l>
          <l n="5" rend="indent(1)" xml:id="CB031_PB-l-5">lorsque j&#8217;ai bris&#233;</l>
          <l n="6" rend="indent(1)" xml:id="CB031_PB-l-6">mes engagements.</l>
          <l n="7" xml:id="CB031_PB-l-7">Mais au soir de ma vie,</l>
          <l n="8" xml:id="CB031_PB-l-8">j&#8217;ai choisi d&#8217;amender</l>
          <l n="9" xml:id="CB031_PB-l-9">tout ce qu&#8217;auparavant</l>
          <l n="10" xml:id="CB031_PB-l-10">j&#8217;ai fait comme un enfant.</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB031_PB-lg-2">
          <l n="1" rend="indent(1)" xml:id="CB031_PB-l-11">Car lorsque j&#8217;essaie</l>
          <l n="2" rend="indent(1)" xml:id="CB031_PB-l-12">de consid&#233;rer</l>
          <l n="3" rend="indent(1)" xml:id="CB031_PB-l-13">ce qu&#8217;il en viendra,</l>
          <l n="4" rend="indent(1)" xml:id="CB031_PB-l-14">de bien distinguer</l>
          <l n="5" rend="indent(1)" xml:id="CB031_PB-l-15">scrupuleusement</l>
          <l n="6" rend="indent(1)" xml:id="CB031_PB-l-16">le vrai et le faux,</l>
          <l n="7" xml:id="CB031_PB-l-17">je me trompe lourdement</l>
          <l n="8" xml:id="CB031_PB-l-18">si j&#8217;esp&#232;re r&#233;colter</l>
          <l n="9" xml:id="CB031_PB-l-19">la moisson de mes vertus</l>
          <l n="10" xml:id="CB031_PB-l-20">en ayant sem&#233; des vices.</l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB031_PB-lg-3">
          <l n="1" rend="indent(1)" xml:id="CB031_PB-l-21">Sans h&#233;siter</l>
          <l n="2" rend="indent(1)" xml:id="CB031_PB-l-22">au carrefour</l>
          <l n="3" rend="indent(1)" xml:id="CB031_PB-l-23">entre deux voies,</l>
          <l n="4" rend="indent(1)" xml:id="CB031_PB-l-24">je n&#8217;appris pas</l>
          <l n="5" rend="indent(1)" xml:id="CB031_PB-l-25">&#224; &#233;viter</l>
          <l n="6" rend="indent(1)" xml:id="CB031_PB-l-26">celle de V&#233;nus,</l>
          <l n="7" xml:id="CB031_PB-l-27">et souvent j&#8217;ai vol&#233;</l>
          <l n="8" xml:id="CB031_PB-l-28">d&#8217;adult&#232;res &#233;treintes ;</l>
          <l n="9" xml:id="CB031_PB-l-29">poursuis donc Dalida,</l>
          <l n="10" xml:id="CB031_PB-l-30">pour assouvir ton sexe !</l>
        </lg>
        <lg type="strophe" n="IV" xml:id="CB031_PB-lg-4">
          <l n="1" xml:id="CB031_PB-l-31">La bouillie des porcs</l>
          <l n="2" xml:id="CB031_PB-l-32">n&#8217;a pas &#244;t&#233; ma faim,</l>
          <l n="3" xml:id="CB031_PB-l-33">elle qui m&#8217;a conduit</l>
          <l n="4" xml:id="CB031_PB-l-34">&#224; glisser vers l&#8217;erreur.</l>
          <l n="5" xml:id="CB031_PB-l-35">Mais l&#8217;Ecriture me conseille</l>
          <l n="6" xml:id="CB031_PB-l-36">la voie des bonnes m&#339;urs,</l>
          <l n="7" xml:id="CB031_PB-l-37">qui m&#8217;offrait largement</l>
          <l n="8" xml:id="CB031_PB-l-38">l&#8217;aliment de ses dons.</l>
        </lg>
        <lg type="strophe" n="V" xml:id="CB031_PB-lg-5">
          <l n="1" rend="indent(1)" xml:id="CB031_PB-l-39">Lorsque je vois</l>
          <l n="2" rend="indent(1)" xml:id="CB031_PB-l-40">ce qu&#8217;&#224; Dina</l>
          <l n="3" rend="indent(1)" xml:id="CB031_PB-l-41">il arriva,</l>
          <l n="4" rend="indent(1)" xml:id="CB031_PB-l-42">je consid&#232;re</l>
          <l n="5" rend="indent(1)" xml:id="CB031_PB-l-43">le r&#233;sultat</l>
          <l n="6" rend="indent(1)" xml:id="CB031_PB-l-44">de ce rapt-l&#224;.</l>
          <l n="7" xml:id="CB031_PB-l-45">Je sais que l&#8217;esprit corrompu</l>
          <l n="8" xml:id="CB031_PB-l-46">&#224; la fin n&#8217;&#233;vitera gu&#232;re</l>
          <l n="9" xml:id="CB031_PB-l-47">la honte de la souillure</l>
          <l n="10" xml:id="CB031_PB-l-48">depuis longtemps contract&#233;e.</l>
        </lg>
        <lg type="strophe" n="VI" xml:id="CB031_PB-lg-6">
          <l n="1" xml:id="CB031_PB-l-49">Je ne veux pas me donner</l>
          <l n="2" xml:id="CB031_PB-l-50">&#224; la mort, plus que m&#233;rit&#233;e,</l>
          <l n="3" xml:id="CB031_PB-l-51">si je reviens &#224; ma vomissure</l>
          <l n="4" xml:id="CB031_PB-l-52">apr&#232;s l&#8217;avoir rejet&#233;e.</l>
          <l n="5" xml:id="CB031_PB-l-53">Je ne me suis pas lib&#233;r&#233;</l>
          <l n="6" xml:id="CB031_PB-l-54">de l&#8217;am&#232;re condamnation</l>
          <l n="7" xml:id="CB031_PB-l-55">si comme un serf je m&#8217;asservis</l>
          <l n="8" xml:id="CB031_PB-l-56">&#224; la souillure des vices.</l>
        </lg>
        <lg type="strophe" n="VII" xml:id="CB031_PB-lg-7">
          <l n="1" xml:id="CB031_PB-l-57">Je refuse d&#8217;aller</l>
          <l n="2" xml:id="CB031_PB-l-58">par les chemins d&#233;voy&#233;s</l>
          <l n="3" rend="indent(1)" xml:id="CB031_PB-l-59">de V&#233;nus,</l>
          <l n="4" xml:id="CB031_PB-l-60">je ne remets pas mes pas</l>
          <l n="5" rend="indent(1)" xml:id="CB031_PB-l-61">sur les traces</l>
          <l n="6" xml:id="CB031_PB-l-62">de la voie qui fut mienne :</l>
          <l n="7" xml:id="CB031_PB-l-63">car on avance en s&#251;ret&#233;</l>
          <l n="8" xml:id="CB031_PB-l-64">sur la royale grand route,</l>
          <l n="9" xml:id="CB031_PB-l-65">mais celui qui s&#8217;en &#233;carte</l>
          <l n="10" xml:id="CB031_PB-l-66">est constamment dans la boue.</l>
        </lg>
        <lg type="strophe" n="VIII" xml:id="CB031_PB-lg-8">
          <l n="1" rend="indent(1)" xml:id="CB031_PB-l-67">Le tr&#244;ne de Rhesi,</l>
          <l n="2" rend="indent(1)" xml:id="CB031_PB-l-68">la ruse de Sinon,</l>
          <l n="3" rend="indent(1)" xml:id="CB031_PB-l-69">ajoute Cic&#233;ron,</l>
          <l n="4" rend="indent(1)" xml:id="CB031_PB-l-70">et la prudence</l>
          <l n="5" rend="indent(1)" xml:id="CB031_PB-l-71">de Z&#233;non :</l>
          <l n="6" xml:id="CB031_PB-l-72">je crois que ce ne serait rien</l>
          <l n="7" xml:id="CB031_PB-l-73">de jouir de tous ces biens</l>
          <l n="8" xml:id="CB031_PB-l-74">si je n&#8217;&#233;vitais par la fuite</l>
          <l n="9" xml:id="CB031_PB-l-75">la Dalida de Samson.</l>
        </lg>
        <lg type="strophe" n="IX" xml:id="CB031_PB-lg-9">
          <l n="1" xml:id="CB031_PB-l-76">Donc pour trouver le pardon</l>
          <l n="2" xml:id="CB031_PB-l-77">de ma mis&#232;re coupable,</l>
          <l n="3" xml:id="CB031_PB-l-78">je dois le chercher</l>
          <l n="4" xml:id="CB031_PB-l-79">dans la cl&#233;mence de Dieu :</l>
          <l n="5" xml:id="CB031_PB-l-80">pour cela et tout le semblable</l>
          <l n="6" xml:id="CB031_PB-l-81">que j&#8217;ai commis, gr&#226;ce de Dieu,</l>
          <l n="7" xml:id="CB031_PB-l-82">toi qui seule peux pardonner,</l>
          <l n="8" xml:id="CB031_PB-l-83">de moi aie piti&#233; !</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>