<TEI>
  <teiHeader />
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB131_hbi_PB-lg-1">
          <l n="1" xml:id="CB131_hbi_PB-l-1">Dis, V&#233;rit&#233; du Christ,</l>
          <l n="2" xml:id="CB131_hbi_PB-l-2">dis, toi si rare et ch&#232;re,</l>
          <l n="3" xml:id="CB131_hbi_PB-l-3">dis, rare Charit&#233;,</l>
          <l n="4" xml:id="CB131_hbi_PB-l-4">o&#249; es-tu &#224; pr&#233;sent ?</l>
          <l n="5" xml:id="CB131_hbi_PB-l-5">Dans la vall&#233;e des visions ?</l>
          <l n="6" xml:id="CB131_hbi_PB-l-6">Sur le tr&#244;ne de Pharaon ?</l>
          <l n="7" xml:id="CB131_hbi_PB-l-7">Ou au pinacle avec N&#233;ron ?</l>
          <l n="8" xml:id="CB131_hbi_PB-l-8">Ou dans la grotte avec Th&#233;on ?</l>
          <l n="9" xml:id="CB131_hbi_PB-l-9">Ou dans la corbeille d&#8217;osier</l>
          <l n="10" xml:id="CB131_hbi_PB-l-10">avec l&#8217;enfant Mo&#239;se en larmes ?</l>
          <l n="11" xml:id="CB131_hbi_PB-l-11">Ou dans la Demeure romaine</l>
          <l n="12" xml:id="CB131_hbi_PB-l-12">avec la Bulle fulmin&#233;e ?</l>
        </lg>
        <lg type="strophe" n="Ia" xml:id="CB131_hbi_PB-lg-2">
          <l n="1" xml:id="CB131_hbi_PB-l-13">Sous les &#233;clairs des bulles fulmin&#233;es</l>
          <l n="2" xml:id="CB131_hbi_PB-l-14">et le tonnerre de la voix du juge,</l>
          <l n="3" xml:id="CB131_hbi_PB-l-15">tandis que le coupable fait appel</l>
          <l n="4" xml:id="CB131_hbi_PB-l-16">et que les sentences s'amoncellent,</l>
          <l n="5" xml:id="CB131_hbi_PB-l-17">la v&#233;rit&#233; est opprim&#233;e,</l>
          <l n="6" xml:id="CB131_hbi_PB-l-18">d&#233;pec&#233;e,</l>
          <l n="7" xml:id="CB131_hbi_PB-l-19">achet&#233;e</l>
          <l n="8" xml:id="CB131_hbi_PB-l-20">et la justice est prostitu&#233;e ;</l>
          <l n="9" xml:id="CB131_hbi_PB-l-21">on va, on court, on revient</l>
          <l n="10" xml:id="CB131_hbi_PB-l-22">&#224; la curie, et on n'obtient rien</l>
          <l n="11" xml:id="CB131_hbi_PB-l-23">avant d'y avoir laiss&#233; ses biens.</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB131_hbi_PB-lg-3">
          <l n="1" xml:id="CB131_hbi_PB-l-24">La Charit&#233; r&#233;pond :</l>
          <l n="2" xml:id="CB131_hbi_PB-l-25">&#171; Homme, pourquoi douter ?</l>
          <l n="3" xml:id="CB131_hbi_PB-l-26">Pourquoi me harceler ?</l>
          <l n="4" xml:id="CB131_hbi_PB-l-27">Je ne suis pas o&#249; tu vas chercher,</l>
          <l n="5" xml:id="CB131_hbi_PB-l-28">ni &#224; l&#8217;est ni au midi,</l>
          <l n="6" xml:id="CB131_hbi_PB-l-29">ni sur la place ni au couvent,</l>
          <l n="7" xml:id="CB131_hbi_PB-l-30">ni sous le lin ni sous la bure,</l>
          <l n="8" xml:id="CB131_hbi_PB-l-31">ni au combat ni au pouvoir :</l>
          <l n="9" xml:id="CB131_hbi_PB-l-32">je viens toujours de J&#233;richo</l>
          <l n="10" xml:id="CB131_hbi_PB-l-33">et je pleure avec le bless&#233;,</l>
          <l n="11" xml:id="CB131_hbi_PB-l-34">celui que n&#8217;ont pas assist&#233;</l>
          <l n="12" xml:id="CB131_hbi_PB-l-35">sur son lit de douleur,</l>
          <l n="13" xml:id="CB131_hbi_PB-l-36">les deux pr&#234;tres qui sont pass&#233;s. &#187;</l>
        </lg>
        <lg type="strophe" n="IIa" xml:id="CB131_hbi_PB-lg-4">
          <l n="1" xml:id="CB131_hbi_PB-l-37">Tu demandes une pr&#233;bende ?</l>
          <l n="2" xml:id="CB131_hbi_PB-l-38">Inutile que tu recommandes</l>
          <l n="3" xml:id="CB131_hbi_PB-l-39">ta vie et tes m&#339;urs excellentes,</l>
          <l n="4" xml:id="CB131_hbi_PB-l-40">tu offenserais ton juge!</l>
          <l n="5" xml:id="CB131_hbi_PB-l-41">Inutile de faire valoir</l>
          <l n="6" xml:id="CB131_hbi_PB-l-42">tes capacit&#233;s,</l>
          <l n="7" xml:id="CB131_hbi_PB-l-43">tu pourras attendre</l>
          <l n="8" xml:id="CB131_hbi_PB-l-44">pas mal de calendes;</l>
          <l n="9" xml:id="CB131_hbi_PB-l-45">d'autres enfin remporteront</l>
          <l n="10" xml:id="CB131_hbi_PB-l-46">l'objet de ton attente,</l>
          <l n="11" xml:id="CB131_hbi_PB-l-47">si tu ne peux te d&#233;fendre</l>
          <l n="12" xml:id="CB131_hbi_PB-l-48">en y mettant prix &#233;gal.</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>