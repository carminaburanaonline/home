<TEI>
  <teiHeader />
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB048_PB-lg-1">
          <l n="1" xml:id="CB048_PB-l-1">
            <seg type="hemistich">Ce que David</seg>
            <seg type="hemistich">a pr&#233;dit en esprit,</seg>
          </l>
          <l n="2" xml:id="CB048_PB-l-2">Dieu &#224; pr&#233;sent</l>
          <l n="3" xml:id="CB048_PB-l-3">
            <seg type="hemistich">nous l'a fait voir</seg>
            <seg type="hemistich">et donn&#233; &#224; comprendre :</seg>
          </l>
          <l n="4" xml:id="CB048_PB-l-4">
            <seg type="hemistich">Le Sarrasin</seg>
            <seg type="hemistich">a souill&#233; le s&#233;pulcre</seg>
          </l>
          <l n="5" xml:id="CB048_PB-l-5">o&#249; fut couch&#233;</l>
          <l n="6" xml:id="CB048_PB-l-6">
            <seg type="hemistich">celui qui pour nous</seg>
            <seg type="hemistich">a &#233;t&#233; crucifi&#233;.</seg>
          </l>
          <l n="7" xml:id="CB048_PB-l-7">
            <seg type="hemistich">Combien il fut</seg>
            <seg type="hemistich">pour nous compatissant,</seg>
          </l>
          <l n="8" xml:id="CB048_PB-l-8">
            <seg type="hemistich">combien il fit</seg>
            <seg type="hemistich">pour notre r&#233;demption,</seg>
          </l>
          <l n="9" xml:id="CB048_PB-l-9">quand il voulut</l>
          <l n="10" xml:id="CB048_PB-l-10">
            <seg type="hemistich">souffrir la mort</seg>
            <seg type="hemistich">sur la croix, innocent !</seg>
          </l>
        </lg>
        <lg type="refrain" xml:id="CB048_PB-lg-2">
          <head>R.</head>
          <l n="1" xml:id="CB048_PB-l-11">Que Dieu se l&#232;ve !</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB048_PB-lg-3">
          <l n="1" xml:id="CB048_PB-l-12">
            <seg type="hemistich">Et qu'il disperse</seg>
            <seg type="hemistich">les ennemis qu'il eut</seg>
          </l>
          <l n="2" xml:id="CB048_PB-l-13">depuis qu'il a laiss&#233;</l>
          <l n="3" xml:id="CB048_PB-l-14">
            <seg type="hemistich">aux Sarrasins</seg>
            <seg type="hemistich">son lieu de s&#233;pulture !</seg>
          </l>
          <l n="4" xml:id="CB048_PB-l-15">[...]</l>
          <l n="5" xml:id="CB048_PB-l-16">
            <seg type="hemistich">La Sareptine</seg>
            <seg type="hemistich">n'a pas gard&#233; longtemps</seg>
          </l>
          <l n="6" xml:id="CB048_PB-l-17">
            <seg type="hemistich">ses deux f&#233;tus ;</seg>
            <seg type="hemistich">quand ils lui ont manqu&#233;,</seg>
          </l>
          <l n="7" xml:id="CB048_PB-l-18">fut d&#233;sol&#233;e,</l>
          <l n="8" xml:id="CB048_PB-l-19">
            <seg type="hemistich">et le sera,</seg>
            <seg type="hemistich">jusqu'&#224; les retrouver.</seg>
          </l>
          <l n="9" xml:id="CB048_PB-l-20">
            <seg type="hemistich">- Car Dieu sera</seg>
            <seg type="hemistich">pour nous compatissant.</seg>
          </l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB048_PB-lg-4">
          <l n="1" xml:id="CB048_PB-l-21">
            <seg type="hemistich">La Sunamite</seg>
            <seg type="hemistich">implore pour son fils</seg>
          </l>
          <l n="2" xml:id="CB048_PB-l-22">qui a p&#233;ri,</l>
          <l n="3" xml:id="CB048_PB-l-23">
            <seg type="hemistich">et que Giezi</seg>
            <seg type="hemistich">tout seul n'a pu gu&#233;rir.</seg>
          </l>
          <l n="4" xml:id="CB048_PB-l-24">
            <seg type="hemistich">Si &#201;lis&#233;e</seg>
            <seg type="hemistich">n'&#233;tait venu &#224; lui,</seg>
          </l>
          <l n="5" xml:id="CB048_PB-l-25">s'il n'e&#251;t pas fait</l>
          <l n="6" xml:id="CB048_PB-l-26">
            <seg type="hemistich">le bouche &#224; bouche,</seg>
            <seg type="hemistich">il serait rest&#233; mort.</seg>
          </l>
          <l n="7" xml:id="CB048_PB-l-27">
            <seg type="hemistich">Si &#201;lis&#233;e</seg>
            <seg type="hemistich">ne vient pas maintenant,</seg>
          </l>
          <l n="8" xml:id="CB048_PB-l-28">
            <seg type="hemistich">si par piti&#233;</seg>
            <seg type="hemistich">il n'&#244;te pas nos fautes,</seg>
          </l>
          <l n="9" xml:id="CB048_PB-l-29">l'&#201;glise alors</l>
          <l n="10" xml:id="CB048_PB-l-30">n'aura pas la Croix qui lui fait d&#233;faut.</l>
        </lg>
        <lg type="strophe" n="IV" xml:id="CB048_PB-lg-5">
          <l n="1" xml:id="CB048_PB-l-31">
            <seg type="hemistich">Et qu'il assiste</seg>
            <seg type="hemistich">en ces combats ceux-l&#224;</seg>
          </l>
          <l n="2" xml:id="CB048_PB-l-32">qu'il aura marqu&#233;s</l>
          <l n="3" xml:id="CB048_PB-l-33">
            <seg type="hemistich">du signe de la croix</seg>
            <seg type="hemistich">qui nous a rachet&#233;s.</seg>
          </l>
          <l n="4" xml:id="CB048_PB-l-34">
            <seg type="hemistich">Que vienne &#224; pr&#233;sent</seg>
            <seg type="hemistich">le temps du pardon,</seg>
          </l>
          <l n="5" xml:id="CB048_PB-l-35">lorsque pourra</l>
          <l n="6" xml:id="CB048_PB-l-36">
            <seg type="hemistich">se lib&#233;rer</seg>
            <seg type="hemistich">qui aura pris la croix.</seg>
          </l>
          <l n="7" xml:id="CB048_PB-l-37">
            <seg type="hemistich">Que maintenant</seg>
            <seg type="hemistich">chacun voie ses actions,</seg>
          </l>
          <l n="8" xml:id="CB048_PB-l-38">
            <seg type="hemistich">combien souvent</seg>
            <seg type="hemistich">il a offens&#233; Dieu.</seg>
          </l>
          <l n="9" xml:id="CB048_PB-l-39">Et s'il le voit</l>
          <l n="10" xml:id="CB048_PB-l-40">
            <seg type="hemistich">et s'il se croise,</seg>
            <seg type="hemistich">il en sera lav&#233;.</seg>
          </l>
        </lg>
        <lg type="strophe" n="V" xml:id="CB048_PB-lg-6">
          <l n="1" xml:id="CB048_PB-l-41">
            <seg type="hemistich">Il s'est lev&#233;,</seg>
            <seg type="hemistich">donc nous sommes tenus</seg>
          </l>
          <l n="2" xml:id="CB048_PB-l-42">de nous lever</l>
          <l n="3" xml:id="CB048_PB-l-43">
            <seg type="hemistich">pour lui bien vite,</seg>
            <seg type="hemistich">et de le secourir.</seg>
          </l>
          <l n="4" xml:id="CB048_PB-l-44">
            <seg type="hemistich">Il a voulu</seg>
            <seg type="hemistich">perdre J&#233;rusalem,</seg>
          </l>
          <l n="5" xml:id="CB048_PB-l-45">pour nous permettre</l>
          <l n="6" xml:id="CB048_PB-l-46">
            <seg type="hemistich">par cette action</seg>
            <seg type="hemistich">de racheter nos fautes.</seg>
          </l>
          <l n="7" xml:id="CB048_PB-l-47">
            <seg type="hemistich">S'il e&#251;t voulu</seg>
            <seg type="hemistich">d&#233;truire l'ennemi</seg>
          </l>
          <l n="8" xml:id="CB048_PB-l-48">
            <seg type="hemistich">sans notre appui,</seg>
            <seg type="hemistich">et lib&#233;rer la terre,</seg>
          </l>
          <l n="9" xml:id="CB048_PB-l-49">il l'aurait pu,</l>
          <l n="10" xml:id="CB048_PB-l-50">
            <seg type="hemistich">puisqu'envers lui</seg>
            <seg type="hemistich">rien ne peut r&#233;sister.</seg>
          </l>
        </lg>
        <lg type="strophe" n="VI" xml:id="CB048_PB-lg-7">
          <l n="1" xml:id="CB048_PB-l-51">&#171; Entends-tu, mon ami, le guetteur aux cr&#233;neaux</l>
          <l n="2" xml:id="CB048_PB-l-52">et ce que son chant annonce ?</l>
          <l n="3" xml:id="CB048_PB-l-53">Nous devons nous quitter, mon aim&#233; !</l>
          <l n="4" xml:id="CB048_PB-l-54">Ainsi es-tu, voici peu de temps, parti d'ici</l>
          <l n="5" xml:id="CB048_PB-l-55">alors que le jour se levait</l>
          <l n="6" xml:id="CB048_PB-l-56">et que la nuit se d&#233;robait &#224; nous comme une fugitive.</l>
          <l n="7" xml:id="CB048_PB-l-57">La nuit est douceur et le jour tourment.</l>
          <l n="8" xml:id="CB048_PB-l-58">H&#233;las, mon bien aim&#233;, je ne puis</l>
          <l n="9" xml:id="CB048_PB-l-59">te cacher plus longtemps.</l>
          <l n="10" xml:id="CB048_PB-l-60">La lumi&#232;re grise de l'aurore nous prive de notre joie.</l>
          <l n="11" xml:id="CB048_PB-l-61">L&#232;ve-toi, chevalier ! &#187;</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>