<TEI>
  <teiHeader/>
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB109_PB-lg-1">
          <l n="1" xml:id="CB109_PB-l-1">Comme l&#8217;&#233;tincelle diverse</l>
          <l n="2" xml:id="CB109_PB-l-2">de l&#8217;amour m&#8217;enflamme,</l>
          <l n="3" xml:id="CB109_PB-l-3">mon esprit se disperse</l>
          <l n="4" xml:id="CB109_PB-l-4">&#224; courir au hasard,</l>
          <l n="5" xml:id="CB109_PB-l-5">tandis que me submerge</l>
          <l n="6" xml:id="CB109_PB-l-6">l&#8217;&#233;cueil cruel de mes soucis.</l>
          <l n="7" xml:id="CB109_PB-l-7">Car &#224; mon vouloir</l>
          <l n="8" xml:id="CB109_PB-l-8">la d&#233;cision de V&#233;nus,</l>
          <l n="9" xml:id="CB109_PB-l-9">que j&#8217;esp&#233;rais meilleure,</l>
          <l n="10" xml:id="CB109_PB-l-10">devient contraire.</l>
        </lg>
        <lg type="refrain" xml:id="CB109_PB-lg-2">
          <head>R.</head>
          <l n="1" xml:id="CB109_PB-l-11">Aimant, c&#8217;est ainsi qu&#8217;en suspens</l>
          <l n="2" xml:id="CB109_PB-l-12">je suis emport&#233; en tous sens.</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB109_PB-lg-3">
          <l n="1" xml:id="CB109_PB-l-13">Quand Apollon s&#8217;enflammait,</l>
          <l n="2" xml:id="CB109_PB-l-14">la courtisait,</l>
          <l n="3" xml:id="CB109_PB-l-15">soupirait pour elle,</l>
          <l n="4" xml:id="CB109_PB-l-16">Daphn&#233; le repoussait,</l>
          <l n="5" xml:id="CB109_PB-l-17">le refusait,</l>
          <l n="6" xml:id="CB109_PB-l-18">se vergognait</l>
          <l n="7" xml:id="CB109_PB-l-19">d&#8217;&#234;tre enlac&#233;e.</l>
          <l n="8" xml:id="CB109_PB-l-20">Celle que j&#8217;implore</l>
          <l n="9" xml:id="CB109_PB-l-21">met ses efforts</l>
          <l n="10" xml:id="CB109_PB-l-22">&#224; m&#8217;&#233;chapper ;</l>
          <l n="11" xml:id="CB109_PB-l-23">mon esp&#233;rance</l>
          <l n="12" xml:id="CB109_PB-l-24">est confondue,</l>
          <l n="13" xml:id="CB109_PB-l-25">car la d&#233;esse de Cyth&#232;re,</l>
          <l n="14" xml:id="CB109_PB-l-26">responsable de cette guerre,</l>
          <l n="15" xml:id="CB109_PB-l-27">me devient contraire.</l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB109_PB-lg-4">
          <l n="1" xml:id="CB109_PB-l-28">Pourquoi m&#8217;&#233;puiser pour V&#233;nus ?</l>
          <l n="2" xml:id="CB109_PB-l-29">Et m&#8217;abstenir d&#8217;insultes et de coups ?</l>
          <l n="3" xml:id="CB109_PB-l-30">Celle qui me peine tant</l>
          <l n="4" xml:id="CB109_PB-l-31">sourit d&#233;sormais &#224; un autre.</l>
          <l n="5" xml:id="CB109_PB-l-32">J&#8217;en meurs,</l>
          <l n="6" xml:id="CB109_PB-l-33">j&#8217;en meurs,</l>
          <l n="7" xml:id="CB109_PB-l-34">j&#8217;en meurs !</l>
          <l n="8" xml:id="CB109_PB-l-35">C&#8217;est lui qu&#8217;elle veut &#233;couter,</l>
          <l n="9" xml:id="CB109_PB-l-36">d&#233;sormais elle apprend le plaisir</l>
          <l n="10" xml:id="CB109_PB-l-37">et se pr&#233;pare &#224; consentir.</l>
          <l n="11" xml:id="CB109_PB-l-38">J&#8217;en meurs,</l>
          <l n="12" xml:id="CB109_PB-l-39">j&#8217;en meurs,</l>
          <l n="13" xml:id="CB109_PB-l-40">j&#8217;en meurs !</l>
          <l n="14" xml:id="CB109_PB-l-41">Celle que je suis fier d&#8217;aimer</l>
          <l n="15" xml:id="CB109_PB-l-42">ne me rend pas la pareille.</l>
          <l n="16" xml:id="CB109_PB-l-43">Pourquoi V&#233;nus supporte-t-elle</l>
          <l n="17" xml:id="CB109_PB-l-44">que celle qui est ma bien aim&#233;e</l>
          <l n="18" xml:id="CB109_PB-l-45">me devienne contraire ?</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>