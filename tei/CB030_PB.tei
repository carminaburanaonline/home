<TEI>
  <teiHeader />
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB030_PB-lg-1">
          <l n="1" xml:id="CB030_PB-l-1">Quand jeunesse fleurissait,</l>
          <l n="2" xml:id="CB030_PB-l-2">
            <seg type="hemistich">j&#8217;aimais,</seg>
            <seg type="hemistich">je pouvais</seg>
          </l>
          <l n="3" xml:id="CB030_PB-l-3">faire ce qu&#8217;il me plaisait</l>
          <l n="4" xml:id="CB030_PB-l-4">et selon ma volont&#233;</l>
          <l n="5" xml:id="CB030_PB-l-5">
            <seg type="hemistich">courir,</seg>
            <seg type="hemistich">accomplir</seg>
          </l>
          <l n="6" xml:id="CB030_PB-l-6">les &#339;uvres de volupt&#233;.</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB030_PB-lg-2">
          <l n="1" xml:id="CB030_PB-l-7">Maintenant agir ainsi,</l>
          <l n="2" xml:id="CB030_PB-l-8">
            <seg type="hemistich">vivre aussi</seg>
            <seg type="hemistich">sans souci</seg>
          </l>
          <l n="3" xml:id="CB030_PB-l-9">et mener si libre vie,</l>
          <l n="4" xml:id="CB030_PB-l-10">l&#8217;&#226;ge adulte l&#8217;interdit,</l>
          <l n="5" xml:id="CB030_PB-l-11">
            <seg type="hemistich">il d&#233;truit,</seg>
            <seg type="hemistich">il abolit</seg>
          </l>
          <l n="6" xml:id="CB030_PB-l-12">l&#8217;ancienne r&#232;gle de vie.</l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB030_PB-lg-3">
          <l n="1" xml:id="CB030_PB-l-13">L&#8217;&#226;ge tendre me disait,</l>
          <l n="2" xml:id="CB030_PB-l-14">
            <seg type="hemistich">m&#8217;enseignait,</seg>
            <seg type="hemistich">me conseillait,</seg>
          </l>
          <l n="3" xml:id="CB030_PB-l-15">oui, cet &#226;ge m&#8217;affirmait :</l>
          <l n="4" xml:id="CB030_PB-l-16">&#171; Il n&#8217;y a rien d&#8217;interdit ! &#187;</l>
          <l n="5" xml:id="CB030_PB-l-17">
            <seg type="hemistich">me faisait</seg>
            <seg type="hemistich">&#8211; et m&#8217;en excusait &#8211;</seg>
          </l>
          <l n="6" xml:id="CB030_PB-l-18">user de tout &#224; l&#8217;envi.</l>
        </lg>
        <lg type="strophe" n="IV" xml:id="CB030_PB-lg-4">
          <l n="1" xml:id="CB030_PB-l-19">Or donc je veux m&#8217;amender,</l>
          <l n="2" xml:id="CB030_PB-l-20">
            <seg type="hemistich">changer,</seg>
            <seg type="hemistich">corriger</seg>
          </l>
          <l n="3" xml:id="CB030_PB-l-21">ce que j&#8217;ai fait de l&#233;ger ;</l>
          <l n="4" xml:id="CB030_PB-l-22">s&#233;rieux je suis devenu,</l>
          <l n="5" xml:id="CB030_PB-l-23">
            <seg type="hemistich">d&#233;sormais,</seg>
            <seg type="hemistich">je compenserai</seg>
          </l>
          <l n="6" xml:id="CB030_PB-l-24">les vices par la vertu.</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>