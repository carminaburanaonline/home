<TEI>
  <teiHeader />
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" xml:id="CB026_ebu_2_PB-lg-1">
          <l n="1" xml:id="CB026_ebu_2_PB-l-1">Si lorsqu'on t'invite &#224; des noces</l>
          <l n="2" xml:id="CB026_ebu_2_PB-l-2">tu y vas</l>
          <l n="3" xml:id="CB026_ebu_2_PB-l-3">sans l'habit nuptial,</l>
          <l n="4" xml:id="CB026_ebu_2_PB-l-4">on te chassera</l>
          <l n="5" xml:id="CB026_ebu_2_PB-l-5">de la cour royale,</l>
          <l n="6" xml:id="CB026_ebu_2_PB-l-6">et si tu vas &#224; la rencontre</l>
          <l n="7" xml:id="CB026_ebu_2_PB-l-7">de l&#8217;&#201;poux sans huile &#224; ta lampe,</l>
          <l n="8" xml:id="CB026_ebu_2_PB-l-8">tu n'es qu'une vierge folle.</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>