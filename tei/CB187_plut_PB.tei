<TEI>
  <teiHeader/>
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB187_plut_PB-lg-1">
          <l n="1" xml:id="CB187_plut_PB-l-1">Ah, les soucis qu&#8217;encourent</l>
          <l n="2" xml:id="CB187_plut_PB-l-2">ceux qui courent la cour !</l>
          <l n="3" xml:id="CB187_plut_PB-l-3">Ah, ceux-l&#224;, leurs man&#339;uvres</l>
          <l n="4" xml:id="CB187_plut_PB-l-4">se poursuivent sans fin !</l>
          <l n="5" xml:id="CB187_plut_PB-l-5">Si de ceux-l&#224; il h&#233;ritait</l>
          <l n="6" xml:id="CB187_plut_PB-l-6">leur fid&#233;lit&#233;,</l>
          <l n="7" xml:id="CB187_plut_PB-l-7">Pylade abandonnerait</l>
          <l n="8" xml:id="CB187_plut_PB-l-8">son Atride bien-aim&#233; ;</l>
          <l n="9" xml:id="CB187_plut_PB-l-9">car un autre Th&#233;s&#233;e</l>
          <l n="10" xml:id="CB187_plut_PB-l-10">rejette son &#226;me-s&#339;ur,</l>
          <l n="11" xml:id="CB187_plut_PB-l-11">l&#224; o&#249; r&#232;gne Prot&#233;e</l>
          <l n="12" xml:id="CB187_plut_PB-l-12">et le Sort joue aux d&#233;s.</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB187_plut_PB-lg-2">
          <l n="1" xml:id="CB187_plut_PB-l-13">De la cour du puissant</l>
          <l n="2" xml:id="CB187_plut_PB-l-14">il faut que tu t&#8217;en ailles,</l>
          <l n="3" xml:id="CB187_plut_PB-l-15">si tu es sans moyens :</l>
          <l n="4" xml:id="CB187_plut_PB-l-16">ton espoir sera vain</l>
          <l n="5" xml:id="CB187_plut_PB-l-17">si ta fortune est mince.</l>
          <l n="6" xml:id="CB187_plut_PB-l-18">De toute fa&#231;on</l>
          <l n="7" xml:id="CB187_plut_PB-l-19">tous n&#8217;ont qu&#8217;une id&#233;e :</l>
          <l n="8" xml:id="CB187_plut_PB-l-20">leur propre int&#233;r&#234;t.</l>
          <l n="9" xml:id="CB187_plut_PB-l-21">Celui dont on ne tire rien</l>
          <l n="10" xml:id="CB187_plut_PB-l-22">y perd sa peine et son temps :</l>
          <l n="11" xml:id="CB187_plut_PB-l-23">tous prennent litt&#233;ralement</l>
          <l n="12" xml:id="CB187_plut_PB-l-24">&#8216;On donnera &#224; qui a d&#233;j&#224;&#8217;.</l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB187_plut_PB-lg-3">
          <l n="1" xml:id="CB187_plut_PB-l-25">On peut gauchir et retourner</l>
          <l n="2" xml:id="CB187_plut_PB-l-26">une censure inconsistante :</l>
          <l n="3" xml:id="CB187_plut_PB-l-27">on casse une dure sentence</l>
          <l n="4" xml:id="CB187_plut_PB-l-28">en faveur de qui peut payer.</l>
          <l n="5" xml:id="CB187_plut_PB-l-29">On interpr&#232;te la loi</l>
          <l n="6" rend="indent(1)" xml:id="CB187_plut_PB-l-30">&#224; volont&#233;,</l>
          <l n="7" rend="indent(1)" xml:id="CB187_plut_PB-l-31">si l&#8217;on entend</l>
          <l n="8" xml:id="CB187_plut_PB-l-32">la monnaie tinter.</l>
          <l n="9" xml:id="CB187_plut_PB-l-33">La peine du coupable fond</l>
          <l n="10" xml:id="CB187_plut_PB-l-34">si les sacs sont pleins de fonds.</l>
          <l n="11" xml:id="CB187_plut_PB-l-35">Cherche-t-on d&#8217;o&#249; vient le mot &#8216;place&#8217; ?</l>
          <l n="12" xml:id="CB187_plut_PB-l-36">Dis que c&#8217;est d&#8217;argent bien plac&#233; !</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>