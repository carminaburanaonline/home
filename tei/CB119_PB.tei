<TEI>
  <teiHeader/>
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB119_PB-lg-1">
          <l n="1" xml:id="CB119_PB-l-1">
            <seg type="hemistich">Sol bien-aim&#233;</seg>
            <seg type="hemistich">de la terre natale,</seg>
          </l>
          <l n="2" xml:id="CB119_PB-l-2">
            <seg type="hemistich">maison joyeuse</seg>
            <seg type="hemistich">et chambre favorable,</seg>
          </l>
          <l n="3" xml:id="CB119_PB-l-3">
            <seg type="hemistich">je vous fuirai</seg>
            <seg type="hemistich">ou demain ou ce jour :</seg>
          </l>
          <l n="4" xml:id="CB119_PB-l-4">
            <seg type="hemistich">je vais mourir</seg>
            <seg type="hemistich">de la rage d&#8217;amour !</seg>
          </l>
          <l n="5" rend="indent(1)" xml:id="CB119_PB-l-5">Exil&#233;...</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB119_PB-lg-2">
          <l n="1" xml:id="CB119_PB-l-6">
            <seg type="hemistich">Adieu pays,</seg>
            <seg type="hemistich">adieu mes compagnons</seg>
          </l>
          <l n="2" xml:id="CB119_PB-l-7">
            <seg type="hemistich">que j&#8217;appr&#233;ciais</seg>
            <seg type="hemistich">de si tendre fa&#231;on.</seg>
          </l>
          <l n="3" xml:id="CB119_PB-l-8">
            <seg type="hemistich">Je fus votre</seg>
            <seg type="hemistich">compagnon d&#8217;&#233;tudes :</seg>
          </l>
          <l n="4" xml:id="CB119_PB-l-9">
            <seg type="hemistich">pleurez sur moi,</seg>
            <seg type="hemistich">je suis perdu pour vous.</seg>
          </l>
          <l n="5" rend="indent(1)" xml:id="CB119_PB-l-10">Br&#251;l&#233;...</l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB119_PB-lg-3">
          <l n="1" xml:id="CB119_PB-l-11">
            <seg type="hemistich">Autant de fleurs</seg>
            <seg type="hemistich">aux vall&#233;es d&#8217;Hybl&#233;,</seg>
          </l>
          <l n="2" xml:id="CB119_PB-l-12">
            <seg type="hemistich">autant de feuilles</seg>
            <seg type="hemistich">aux for&#234;ts de Dodone,</seg>
          </l>
          <l n="3" xml:id="CB119_PB-l-13">
            <seg type="hemistich">et de poissons</seg>
            <seg type="hemistich">nageant dans l&#8217;oc&#233;an</seg>
          </l>
          <l n="4" xml:id="CB119_PB-l-14">
            <seg type="hemistich">que de douleurs</seg>
            <seg type="hemistich">pour celui qu&#8217;amour prend.</seg>
          </l>
          <l n="5" rend="indent(1)" xml:id="CB119_PB-l-15">A quel point !</l>
        </lg>
        <lg type="strophe" n="IV" xml:id="CB119_PB-lg-4">
          <l n="1" xml:id="CB119_PB-l-16">
            <seg type="hemistich">Bless&#233; du feu</seg>
            <seg type="hemistich">tout nouveau de V&#233;nus,</seg>
          </l>
          <l n="2" xml:id="CB119_PB-l-17">
            <seg type="hemistich">mon c&#339;ur, jusqu&#8217;ici,</seg>
            <seg type="hemistich">ignorait  tout cela.</seg>
          </l>
          <l n="3" xml:id="CB119_PB-l-18">
            <seg type="hemistich">Comme le dit</seg>
            <seg type="hemistich">justement le proverbe :</seg>
          </l>
          <l n="4" xml:id="CB119_PB-l-19">
            <seg type="hemistich">&#171; O&#249; est l&#8217;amour</seg>
            <seg type="hemistich">est aussi le malheur &#187;</seg>
          </l>
          <l n="5" rend="indent(1)" xml:id="CB119_PB-l-20">affreux...</l>
        </lg>
        <lg type="strophe" n="V" xml:id="CB119_PB-lg-5">
          <l n="1" xml:id="CB119_PB-l-21">
            <seg type="hemistich">H&#233;las, douleur,</seg>
            <seg type="hemistich">quel triste r&#233;sultat !</seg>
          </l>
          <l n="2" xml:id="CB119_PB-l-22">
            <seg type="hemistich">Les amoureux</seg>
            <seg type="hemistich">br&#251;lent de trop de flammes.</seg>
          </l>
          <l n="3" xml:id="CB119_PB-l-23">
            <seg type="hemistich">Toujours V&#233;nus</seg>
            <seg type="hemistich">nourrit d&#8217;autres soupirs,</seg>
          </l>
          <l n="4" xml:id="CB119_PB-l-24">
            <seg type="hemistich">quelle douceur</seg>
            <seg type="hemistich">un jour la fl&#233;chira ?</seg>
          </l>
          <l n="5" rend="indent(1)" xml:id="CB119_PB-l-25">C&#8217;est trop !</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>