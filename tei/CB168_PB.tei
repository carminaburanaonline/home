<TEI>
  <teiHeader />
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB168_PB-lg-1">
          <l n="1" xml:id="CB168_PB-l-1">Que mon aim&#233;e, &#224; l&#8217;an nouvel</l>
          <l n="2" xml:id="CB168_PB-l-2">ait le salut et la joie !</l>
          <l n="3" rend="indent(1)" xml:id="CB168_PB-l-3">Qu&#8217;elle sourie,</l>
          <l n="4" xml:id="CB168_PB-l-4">elle autour de qui s&#8217;enroule</l>
          <l n="5" xml:id="CB168_PB-l-5">cette farandole, et je confirme</l>
          <l n="6" rend="indent(1)" xml:id="CB168_PB-l-6">en la chantant :</l>
          <l n="7" xml:id="CB168_PB-l-7">
            <seg type="hemistich">au monde il n&#8217;en est pas</seg>
            <seg type="hemistich">d&#8217;aussi belle que celle-l&#224; !</seg>
          </l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB168_PB-lg-2">
          <l n="1" xml:id="CB168_PB-l-8">C&#8217;est un feu ardent,</l>
          <l n="2" xml:id="CB168_PB-l-9">cette amie &#224; moi,</l>
          <l n="3" xml:id="CB168_PB-l-10">toute &#233;tincelante</l>
          <l n="4" xml:id="CB168_PB-l-11">de douce bont&#233;.</l>
          <l n="5" xml:id="CB168_PB-l-12">Et cela m&#8217;attire</l>
          <l n="6" xml:id="CB168_PB-l-13">vers de telles joies,</l>
          <l n="7" xml:id="CB168_PB-l-14">
            <seg type="hemistich">revendiqu&#233; par V&#233;nus,</seg>
            <seg type="hemistich">je m&#8217;attriste &#224; grands soupirs.</seg>
          </l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB168_PB-lg-3">
          <l n="1" xml:id="CB168_PB-l-15">Mon aim&#233;e est accueillante,</l>
          <l n="2" xml:id="CB168_PB-l-16">de teint blanche et rose,</l>
          <l n="3" xml:id="CB168_PB-l-17">digne d&#8217;&#234;tre aim&#233;e.</l>
          <l n="4" xml:id="CB168_PB-l-18">V&#233;nus, d&#233;esse d&#8217;amour,</l>
          <l n="5" xml:id="CB168_PB-l-19">je me rends &#224; toi,</l>
          <l n="6" xml:id="CB168_PB-l-20">car j&#8217;ai bien besoin</l>
          <l n="7" xml:id="CB168_PB-l-21">
            <seg type="hemistich">de ton secours : d&#233;j&#224;</seg>
            <seg type="hemistich">je br&#251;le et je me meurs pour elle.</seg>
          </l>
        </lg>
        <lg type="strophe" n="IV" xml:id="CB168_PB-lg-4">
          <l n="1" xml:id="CB168_PB-l-22">Louez-la tous, la mienne amie,</l>
          <l n="2" xml:id="CB168_PB-l-23">si pudique, et d&#233;lectable,</l>
          <l n="3" rend="indent(1)" xml:id="CB168_PB-l-24">et si aimable !</l>
          <l n="4" xml:id="CB168_PB-l-25">Je l&#8217;aime de tout mon c&#339;ur.</l>
          <l n="5" xml:id="CB168_PB-l-26">Elle me rend triste mais plein de vigueur</l>
          <l n="6" rend="indent(1)" xml:id="CB168_PB-l-27">et de bonheur,</l>
          <l n="7" xml:id="CB168_PB-l-28">
            <seg type="hemistich">Je la ch&#233;ris plus que tout,</seg>
            <seg type="hemistich">je la v&#233;n&#232;re comme une d&#233;esse.</seg>
          </l>
        </lg>
      </div>
    </body>
  </text>
</TEI>