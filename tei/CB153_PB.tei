<TEI>
  <teiHeader />
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB153_PB-lg-1">
          <l n="1" xml:id="CB153_PB-l-1">Il est pass&#233;, le temps des gel&#233;es,</l>
          <l n="2" rend="indent(1)" xml:id="CB153_PB-l-2">le monde se renouvelle,</l>
          <l n="3" xml:id="CB153_PB-l-3">le printemps revient tout fleuri.</l>
          <l n="4" rend="indent(1)" xml:id="CB153_PB-l-4">Les choses reprennent forme,</l>
          <l n="5" rend="indent(1)" xml:id="CB153_PB-l-5">l&#8217;oiseau se met &#224; chanter,</l>
          <l n="6" rend="indent(1)" xml:id="CB153_PB-l-6">et en chantant se r&#233;jouit ; ...</l>
          <l n="7" rend="indent(2)" xml:id="CB153_PB-l-7">plus transparent,</l>
          <l n="8" rend="indent(2)" xml:id="CB153_PB-l-8">plus caressant,</l>
          <l n="9" xml:id="CB153_PB-l-9">l&#8217;air se remplit de douceur.</l>
          <l n="10" rend="indent(2)" xml:id="CB153_PB-l-10">D&#233;j&#224; en fleurs,</l>
          <l n="11" rend="indent(2)" xml:id="CB153_PB-l-11">d&#233;j&#224; en feuilles,</l>
          <l n="12" xml:id="CB153_PB-l-12">la for&#234;t &#233;paissit sa chevelure.</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB153_PB-lg-2">
          <l n="1" xml:id="CB153_PB-l-13">Les jolies jeunes filles</l>
          <l n="2" rend="indent(1)" xml:id="CB153_PB-l-14">jouent dans les prairies,</l>
          <l n="3" xml:id="CB153_PB-l-15">et leurs chants de renouveau</l>
          <l n="4" xml:id="CB153_PB-l-16">r&#233;sonnent avec douceur.</l>
          <l n="5" rend="indent(1)" xml:id="CB153_PB-l-17">Elles ont la faveur</l>
          <l n="6" rend="indent(1)" xml:id="CB153_PB-l-18">des oiseaux chanteurs,</l>
          <l n="7" xml:id="CB153_PB-l-19">la terre sem&#233;e de fleurs</l>
          <l n="8" xml:id="CB153_PB-l-20">s&#8217;y accorde par l&#8217;odeur.</l>
          <l n="9" rend="indent(2)" xml:id="CB153_PB-l-21">Or donc le c&#339;ur</l>
          <l n="10" rend="indent(2)" xml:id="CB153_PB-l-22">est encercl&#233;,</l>
          <l n="11" rend="indent(1)" xml:id="CB153_PB-l-23">il est atteint par l&#8217;amour,</l>
          <l n="12" rend="indent(2)" xml:id="CB153_PB-l-24">lorsque les vierges</l>
          <l n="13" rend="indent(2)" xml:id="CB153_PB-l-25">et les oiseaux</l>
          <l n="14" xml:id="CB153_PB-l-26">font retentir leur clameur.</l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB153_PB-lg-3">
          <l n="1" xml:id="CB153_PB-l-27">C&#8217;est alors qu&#8217;il tend ses filets,</l>
          <l n="2" rend="indent(2)" xml:id="CB153_PB-l-28">l&#8217;enfant au carquois,</l>
          <l n="3" xml:id="CB153_PB-l-29">&#224; qui la cour des dieux</l>
          <l n="4" rend="indent(2)" xml:id="CB153_PB-l-30">doit bien se soumettre,</l>
          <l n="5" rend="indent(2)" xml:id="CB153_PB-l-31">car sa seigneurie</l>
          <l n="6" rend="indent(2)" xml:id="CB153_PB-l-32">est vraiment trop large.</l>
          <l n="7" xml:id="CB153_PB-l-33">Par lui j&#8217;ai &#233;t&#233; vaincu,</l>
          <l n="8" rend="indent(2)" xml:id="CB153_PB-l-34">et j&#8217;en reste bless&#233; :</l>
          <l n="9" rend="indent(1)" xml:id="CB153_PB-l-35">d&#8217;abord je me suis battu</l>
          <l n="10" rend="indent(2)" xml:id="CB153_PB-l-36">et au d&#233;but</l>
          <l n="11" rend="indent(2)" xml:id="CB153_PB-l-37">j&#8217;avais lutt&#233;,</l>
          <l n="12" rend="indent(2)" xml:id="CB153_PB-l-38">mais au final</l>
          <l n="13" rend="indent(2)" xml:id="CB153_PB-l-39">par son enfant</l>
          <l n="14" rend="indent(1)" xml:id="CB153_PB-l-40">je fus soumis &#224; V&#233;nus.</l>
        </lg>
        <lg type="strophe" n="IV" xml:id="CB153_PB-lg-4">
          <l n="1" xml:id="CB153_PB-l-41">Bless&#233; de son trait de fl&#232;che,</l>
          <l n="2" rend="indent(1)" xml:id="CB153_PB-l-42">j&#8217;en ai aim&#233; une,</l>
          <l n="3" xml:id="CB153_PB-l-43">que je me suis attach&#233;e</l>
          <l n="4" rend="indent(1)" xml:id="CB153_PB-l-44">d&#8217;un pacte solide.</l>
          <l n="5" rend="indent(1)" xml:id="CB153_PB-l-45">J&#8217;ai jur&#233; ma foi,</l>
          <l n="6" rend="indent(1)" xml:id="CB153_PB-l-46">et je l&#8217;ai gard&#233;e,</l>
          <l n="7" xml:id="CB153_PB-l-47">je me suis tout consacr&#233;</l>
          <l n="8" rend="indent(1)" xml:id="CB153_PB-l-48">&#224; chose si tendre.</l>
          <l n="9" rend="indent(2)" xml:id="CB153_PB-l-49">Comme ils sont doux</l>
          <l n="10" rend="indent(2)" xml:id="CB153_PB-l-50">les doux baisers</l>
          <l n="11" xml:id="CB153_PB-l-51">de cette enfant, j&#8217;y ai go&#251;t&#233; :</l>
          <l n="12" rend="indent(2)" xml:id="CB153_PB-l-52">ni la cannelle</l>
          <l n="13" rend="indent(2)" xml:id="CB153_PB-l-53">ni le baume</l>
          <l n="14" xml:id="CB153_PB-l-54">ne seraient un miel aussi doux !</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>