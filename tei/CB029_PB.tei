<TEI>
  <teiHeader/>
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB029_PB-lg-1">
          <l n="1" xml:id="CB029_PB-l-1">Dans le gouffre de mis&#232;re</l>
          <l n="2" xml:id="CB029_PB-l-2">et le bourbier de luxure,</l>
          <l n="3" xml:id="CB029_PB-l-3">tu te vautres, o Pamphile,</l>
          <l n="4" xml:id="CB029_PB-l-4">perdant ton temps inutile !</l>
          <l n="5" rend="indent(1)" xml:id="CB029_PB-l-5">Pourquoi ne crains-tu pas</l>
          <l n="6" rend="indent(1)" xml:id="CB029_PB-l-6">la col&#232;re du ciel,</l>
          <l n="7" rend="indent(1)" xml:id="CB029_PB-l-7">la d&#233;rision de tous,</l>
          <l n="8" rend="indent(1)" xml:id="CB029_PB-l-8">alors que tu d&#233;truis</l>
          <l n="9" rend="indent(1)" xml:id="CB029_PB-l-9">ton corps, tes biens, ton &#226;me ?</l>
          <l n="10" xml:id="CB029_PB-l-10">Sauve au moins la derni&#232;re</l>
          <l n="11" xml:id="CB029_PB-l-11">petite portion de ta vie,</l>
          <l n="12" xml:id="CB029_PB-l-12">en offrant aux saints du ciel,</l>
          <l n="13" xml:id="CB029_PB-l-13">pour les fleurs de la jeunesse,</l>
          <l n="14" xml:id="CB029_PB-l-14">le chaume de la vieillesse !</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB029_PB-lg-2">
          <l n="1" xml:id="CB029_PB-l-15">Peut-&#234;tre qu&#8216;au jeu de V&#233;nus</l>
          <l n="2" xml:id="CB029_PB-l-16">tu br&#251;les au del&#224; de tes forces</l>
          <l n="3" xml:id="CB029_PB-l-17">pour que le d&#233;go&#251;t de l&#8217;amour</l>
          <l n="4" rend="indent(1)" xml:id="CB029_PB-l-18">finisse par t&#8217;en gu&#233;rir.</l>
          <l n="5" xml:id="CB029_PB-l-19">Mais si tu t&#8216;&#233;puises &#224; tel point,</l>
          <l n="6" rend="indent(1)" xml:id="CB029_PB-l-20">dess&#233;ch&#233; jusqu&#8217;&#224; la mo&#235;lle,</l>
          <l n="7" rend="indent(1)" xml:id="CB029_PB-l-21">jusqu&#8217;&#224; y prendre la fi&#232;vre,</l>
          <l n="8" rend="indent(1)" xml:id="CB029_PB-l-22">tu n&#8217;y gagnes pourtant rien</l>
          <l n="9" xml:id="CB029_PB-l-23">quand tu t&#8217;affaiblis un moment ;</l>
          <l n="10" xml:id="CB029_PB-l-24">car l&#8217;hydre se redressera</l>
          <l n="11" xml:id="CB029_PB-l-25">plus touffue, avec plus de t&#234;tes,</l>
          <l n="12" xml:id="CB029_PB-l-26">et Ant&#233;e se rel&#232;vera</l>
          <l n="13" xml:id="CB029_PB-l-27">plus fort apr&#232;s &#234;tre tomb&#233;.</l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB029_PB-lg-3">
          <l n="1" xml:id="CB029_PB-l-28">Pour rester ferme sur tes pieds</l>
          <l n="2" xml:id="CB029_PB-l-29">sans tomber trop facilement,</l>
          <l n="3" xml:id="CB029_PB-l-30">prends garde au gouffre devant toi</l>
          <l n="4" xml:id="CB029_PB-l-31">en te gardant bien du p&#233;ch&#233;.</l>
          <l n="5" xml:id="CB029_PB-l-32">Mais si elle t&#8217;a tourment&#233;,</l>
          <l n="6" rend="indent(1)" xml:id="CB029_PB-l-33">si elle t&#8217;a empoign&#233;,</l>
          <l n="7" rend="indent(1)" xml:id="CB029_PB-l-34">   l&#8217;Egyptienne,</l>
          <l n="8" rend="indent(1)" xml:id="CB029_PB-l-35">   fuis aussit&#244;t</l>
          <l n="9" xml:id="CB029_PB-l-36">en abandonnant ton manteau,</l>
          <l n="10" xml:id="CB029_PB-l-37">n&#8217;aie pas la folie de lutter !</l>
          <l n="11" xml:id="CB029_PB-l-38">Car dans ce genre de combat</l>
          <l n="12" xml:id="CB029_PB-l-39">celui qui tient ferme est vaincu,</l>
          <l n="13" xml:id="CB029_PB-l-40">mais celui qui sait reculer</l>
          <l n="14" xml:id="CB029_PB-l-41">en fuyant se fait respecter.</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>