  <text>
    <body>
      <div type="poem" xml:lang="french">
        <lg type="strophe" n="I" xml:id="CB014_plut_PB-lg-1">
          <l n="1" xml:id="CB014_plut_PB-l-1">O si changeant caprice de Fortune,</l>
          <l n="2" xml:id="CB014_plut_PB-l-2">jugeant de tout en douteux tribunal,</l>
          <l n="3" xml:id="CB014_plut_PB-l-3">tu dispenses de notables faveurs</l>
          <l n="4" xml:id="CB014_plut_PB-l-4">&#224; celui que ton bon vouloir ch&#233;rit,</l>
          <l n="5" xml:id="CB014_plut_PB-l-5">pour qu&#8217;il atteigne le sommet de ta roue,</l>
          <l n="6" xml:id="CB014_plut_PB-l-6">accordant cependant tes faveurs &#224; rebours,</l>
          <l n="7" xml:id="CB014_plut_PB-l-7">quand tu &#233;l&#232;ves un pauvre du fumier,</l>
          <l n="8" xml:id="CB014_plut_PB-l-8">quand tu transformes un rh&#233;teur en seigneur.</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>