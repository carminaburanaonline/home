<TEI>
  <teiHeader/>
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB131_plut_PB-lg-1">
          <l n="1" xml:id="CB131_plut_PB-l-1">Dis, V&#233;rit&#233; du Christ,</l>
          <l n="2" xml:id="CB131_plut_PB-l-2">dis, toi si rare et ch&#232;re,</l>
          <l n="3" xml:id="CB131_plut_PB-l-3">dis, rare Charit&#233;,</l>
          <l n="4" xml:id="CB131_plut_PB-l-4">o&#249; es-tu &#224; pr&#233;sent ?</l>
          <l n="5" xml:id="CB131_plut_PB-l-5">Dans la vall&#233;e des visions ?</l>
          <l n="6" xml:id="CB131_plut_PB-l-6">Sur le tr&#244;ne de Pharaon ?</l>
          <l n="7" xml:id="CB131_plut_PB-l-7">Ou au pinacle avec N&#233;ron ?</l>
          <l n="8" xml:id="CB131_plut_PB-l-8">Ou dans la grotte avec Th&#233;on ?</l>
          <l n="9" xml:id="CB131_plut_PB-l-9">Ou dans la corbeille d&#8217;osier</l>
          <l n="10" xml:id="CB131_plut_PB-l-10">avec l&#8217;enfant Mo&#239;se en larmes ?</l>
          <l n="11" xml:id="CB131_plut_PB-l-11">Ou dans la Demeure romaine</l>
          <l n="12" xml:id="CB131_plut_PB-l-12">avec la Bulle fulmin&#233;e ?</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB131_plut_PB-lg-2">
          <l n="1" xml:id="CB131_plut_PB-l-13">La Charit&#233; r&#233;pond :</l>
          <l n="2" xml:id="CB131_plut_PB-l-14">&#171; Homme, pourquoi douter ?</l>
          <l n="3" xml:id="CB131_plut_PB-l-15">Pourquoi me harceler ?</l>
          <l n="4" xml:id="CB131_plut_PB-l-16">Je ne suis pas o&#249; tu vas chercher,</l>
          <l n="5" xml:id="CB131_plut_PB-l-17">ni &#224; l&#8217;est ni au midi,</l>
          <l n="6" xml:id="CB131_plut_PB-l-18">ni sur la place ni au couvent,</l>
          <l n="7" xml:id="CB131_plut_PB-l-19">ni sous le lin ni sous la bure,</l>
          <l n="8" xml:id="CB131_plut_PB-l-20">ni au combat ni au pouvoir :</l>
          <l n="9" xml:id="CB131_plut_PB-l-21">je viens toujours de J&#233;richo</l>
          <l n="10" xml:id="CB131_plut_PB-l-22">et je pleure avec le bless&#233;,</l>
          <l n="11" xml:id="CB131_plut_PB-l-23">celui que n&#8217;ont pas assist&#233;</l>
          <l n="12" xml:id="CB131_plut_PB-l-24">sur son lit de douleur,</l>
          <l n="13" xml:id="CB131_plut_PB-l-25">les deux pr&#234;tres qui sont pass&#233;s. &#187;</l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB131_plut_PB-lg-3">
          <l n="1" xml:id="CB131_plut_PB-l-26">Voix du proph&#232;te,</l>
          <l n="2" xml:id="CB131_plut_PB-l-27">&#244; Nathan, &#233;l&#232;ve la voix :</l>
          <l n="3" xml:id="CB131_plut_PB-l-28">la faute de David</l>
          <l n="4" xml:id="CB131_plut_PB-l-29">semble &#224; pr&#233;sent modique.</l>
          <l n="5" xml:id="CB131_plut_PB-l-30">Nathan r&#233;pond : &#171; Je ne crierai pas,</l>
          <l n="6" xml:id="CB131_plut_PB-l-31">sur David je ne pleurerai pas. &#187;</l>
          <l n="7" xml:id="CB131_plut_PB-l-32">Puisque la robe du Christ est d&#233;chir&#233;e,</l>
          <l n="8" xml:id="CB131_plut_PB-l-33">contre le Christ que le Christ soit t&#233;moin :</l>
          <l n="9" xml:id="CB131_plut_PB-l-34">malheur &#224; vous, hypocrites,</l>
          <l n="10" xml:id="CB131_plut_PB-l-35">tout &#224; filtrer des moustiques !</l>
          <l n="11" xml:id="CB131_plut_PB-l-36">Rendez &#224; C&#233;sar ce qui est sien</l>
          <l n="12" xml:id="CB131_plut_PB-l-37">pour rendre au Christ votre service.</l>
        </lg>
        <lg type="strophe" n="Ia" xml:id="CB131_plut_PB-lg-4">
          <l n="1" xml:id="CB131_plut_PB-l-38">Sous les &#233;clairs des bulles fulmin&#233;es</l>
          <l n="2" xml:id="CB131_plut_PB-l-39">et le tonnerre de la voix du juge,</l>
          <l n="3" xml:id="CB131_plut_PB-l-40">tandis que le coupable fait appel</l>
          <l n="4" xml:id="CB131_plut_PB-l-41">et que les sentences s'amoncellent,</l>
          <l n="5" xml:id="CB131_plut_PB-l-42">la v&#233;rit&#233; est opprim&#233;e,</l>
          <l n="6" xml:id="CB131_plut_PB-l-43">d&#233;pec&#233;e,</l>
          <l n="7" xml:id="CB131_plut_PB-l-44">achet&#233;e</l>
          <l n="8" xml:id="CB131_plut_PB-l-45">et la justice est prostitu&#233;e ;</l>
          <l n="9" xml:id="CB131_plut_PB-l-46">on va, on court, on revient</l>
          <l n="10" xml:id="CB131_plut_PB-l-47">&#224; la curie, et on n'obtient rien</l>
          <l n="11" xml:id="CB131_plut_PB-l-48">avant d'y avoir laiss&#233; ses biens.</l>
        </lg>
<lg type="strophe" n="IIa" xml:id="CB131_plut_PB-lg-5">
          <l n="1" xml:id="CB131_plut_PB-l-49">Les huissiers du pape sont</l>
          <l n="2" xml:id="CB131_plut_PB-l-50">plus sourds que Cerb&#232;re.</l>
          <l n="3" xml:id="CB131_plut_PB-l-51">C'est sans espoir, tu peux pleurer,</l>
          <l n="4" xml:id="CB131_plut_PB-l-52">quand bien m&#234;me tu serais</l>
          <l n="5" xml:id="CB131_plut_PB-l-53">Orph&#233;e, que Pluton,</l>
          <l n="6" xml:id="CB131_plut_PB-l-54">le dieu des enfers,</l>
          <l n="7" xml:id="CB131_plut_PB-l-55">daigna exaucer,</l>
          <l n="8" xml:id="CB131_plut_PB-l-56">tu ne finiras pas m&#234;me de parler,</l>
          <l n="9" xml:id="CB131_plut_PB-l-57">si un marteau d'argent</l>
          <l n="10" xml:id="CB131_plut_PB-l-58">ne toque pas &#224; la porte</l>
          <l n="11" xml:id="CB131_plut_PB-l-59">que garde Prot&#233;e</l>
          <l n="12" xml:id="CB131_plut_PB-l-60">aux couleurs vari&#233;es.</l>
        </lg>
        <lg type="strophe" n="IIIa" xml:id="CB131_plut_PB-lg-6">
          <l n="1" xml:id="CB131_plut_PB-l-61">Tu demandes une pr&#233;bende ?</l>
          <l n="2" xml:id="CB131_plut_PB-l-62">Inutile que tu recommandes</l>
          <l n="3" xml:id="CB131_plut_PB-l-63">ta vie et tes m&#339;urs excellentes,</l>
          <l n="4" xml:id="CB131_plut_PB-l-64">tu offenserais ton juge!</l>
          <l n="5" xml:id="CB131_plut_PB-l-65">Inutile de faire valoir</l>
          <l n="6" xml:id="CB131_plut_PB-l-66">tes capacit&#233;s,</l>
          <l n="7" xml:id="CB131_plut_PB-l-67">tu pourras attendre</l>
          <l n="8" xml:id="CB131_plut_PB-l-68">pas mal de calendes;</l>
          <l n="9" xml:id="CB131_plut_PB-l-69">d'autres enfin remporteront</l>
          <l n="10" xml:id="CB131_plut_PB-l-70">l'objet de ton attente,</l>
          <l n="11" xml:id="CB131_plut_PB-l-71">si tu ne peux te d&#233;fendre</l>
          <l n="12" xml:id="CB131_plut_PB-l-72">en y mettant prix &#233;gal.</l>
        </lg>
        <lg type="strophe" n="IVa" xml:id="CB131_plut_PB-lg-7">
          <l n="1" xml:id="CB131_plut_PB-l-73">Tant qu'il supplie Dana&#233;,</l>
          <l n="2" xml:id="CB131_plut_PB-l-74">Jupiter y perd sa peine;</l>
          <l n="3" xml:id="CB131_plut_PB-l-75">mais il la d&#233;flore</l>
          <l n="4" xml:id="CB131_plut_PB-l-76">d&#233;s qu'il se colore d'or:</l>
          <l n="5" xml:id="CB131_plut_PB-l-77">rien de plus puissant que l'or,</l>
          <l n="6" xml:id="CB131_plut_PB-l-78">rien de plus persuasif,</l>
          <l n="7" xml:id="CB131_plut_PB-l-79">m&#233;me Cic&#233;ron</l>
          <l n="8" xml:id="CB131_plut_PB-l-80">n'est pas plus &#233;loquent.</l>
          <l n="9" xml:id="CB131_plut_PB-l-81">Mais il br&#251;le plus &#226;crement</l>
          <l n="10" xml:id="CB131_plut_PB-l-82">ceux qu'il honore le plus;</l>
          <l n="11" xml:id="CB131_plut_PB-l-83">rien de plus juste: Crassus</l>
          <l n="12" xml:id="CB131_plut_PB-l-84">dut bien l'avaler bouillant !</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>