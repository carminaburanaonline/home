  <teiHeader />
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB131_guelf_1099_PB-lg-1">
          <l n="1" xml:id="CB131_guelf_1099_PB-l-1">Dis, V&#233;rit&#233; du Christ,</l>
          <l n="2" xml:id="CB131_guelf_1099_PB-l-2">dis, toi si rare et ch&#232;re,</l>
          <l n="3" xml:id="CB131_guelf_1099_PB-l-3">dis, rare Charit&#233;,</l>
          <l n="4" xml:id="CB131_guelf_1099_PB-l-4">o&#249; es-tu &#224; pr&#233;sent ?</l>
          <l n="5" xml:id="CB131_guelf_1099_PB-l-5">Dans la vall&#233;e des visions ?</l>
          <l n="6" xml:id="CB131_guelf_1099_PB-l-6">Sur le tr&#244;ne de Pharaon ?</l>
          <l n="7" xml:id="CB131_guelf_1099_PB-l-7">Ou au pinacle avec N&#233;ron ?</l>
          <l n="8" xml:id="CB131_guelf_1099_PB-l-8">Ou dans la grotte avec Th&#233;on ?</l>
          <l n="9" xml:id="CB131_guelf_1099_PB-l-9">Ou dans la corbeille d&#8217;osier</l>
          <l n="10" xml:id="CB131_guelf_1099_PB-l-10">avec l&#8217;enfant Mo&#239;se en larmes ?</l>
          <l n="11" xml:id="CB131_guelf_1099_PB-l-11">Ou dans la Demeure romaine</l>
          <l n="12" xml:id="CB131_guelf_1099_PB-l-12">avec la Bulle fulmin&#233;e ?</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>