<TEI>
  <teiHeader/>
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I">
          <l n="1">Au temps du doux printemps</l>
          <l n="2">voil&#224; Julienne avec sa s&#339;ur</l>
          <l n="3" rend="indent(1)">sous l'arbre en fleur.</l>
          <l n="4" rend="indent(1)">Amour-douceur!</l>
        </lg>
        <lg type="refrain">
          <head>Refrain</head>
          <l n="1">Qui se passe de toi &#224; cette heure</l>
          <l n="2" rend="indent(1)">perd sa valeur.</l>
        </lg>
        <lg type="strophe" n="II">
          <l n="1">Les arbres sont en fleur,</l>
          <l n="2">les oiseaux chantent avec ardeur,</l>
          <l n="3">les vierges en sentent la ti&#233;deur.</l>
          <l n="4" rend="indent(1)">Amour-douceur!</l>
        </lg>
        <lg type="strophe" n="III">
          <l n="1">Les herbes sont en fleur,</l>
          <l n="2">les vierges en ch&#339;ur</l>
          <l n="3">chantent pour le plus haut des dieux.</l>
          <l n="4" rend="indent(1)">Amour-douceur!</l>
        </lg>
        <lg type="strophe" n="IV">
          <l n="1">Si je voyais celle que je veux</l>
          <l n="2">au lieu des scribes de Silos</l>
          <l n="3">ou même du fils du roi !</l>
          <l n="4" rend="indent(1)">Amour-douceur !</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>