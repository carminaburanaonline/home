<TEI>
  <teiHeader/>
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" xml:id="CB027_ebu_PB-lg-1">
          <l n="1" xml:id="CB027_ebu_PB-l-1">Il est bon de s&#8217;en remettre</l>
          <l n="2" xml:id="CB027_ebu_PB-l-2">au Seigneur absolu,</l>
          <l n="3" xml:id="CB027_ebu_PB-l-3">l&#8217;espoir, il est bon de le mettre</l>
          <l n="4" xml:id="CB027_ebu_PB-l-4">l&#224; o&#249; notre espoir a son but.</l>
          <l n="5" xml:id="CB027_ebu_PB-l-5">Toi qui con&#231;ois de l&#8217;espoir</l>
          <l n="6" xml:id="CB027_ebu_PB-l-6">de la puissance des rois</l>
          <l n="7" xml:id="CB027_ebu_PB-l-7">et non de la bont&#233; de Dieu,</l>
          <l n="8" rend="indent(1)" xml:id="CB027_ebu_PB-l-8">tu fais erreur,</l>
          <l n="9" rend="indent(1)" xml:id="CB027_ebu_PB-l-9">et tu t&#8217;exclus</l>
          <l n="10" xml:id="CB027_ebu_PB-l-10">de la cour du roi souverain.</l>
          <l n="11" xml:id="CB027_ebu_PB-l-11">Pourquoi sur l&#8217;amas de tes biens</l>
          <l n="12" xml:id="CB027_ebu_PB-l-12">entasses-tu ton p&#233;ch&#233; ?</l>
          <l n="13" xml:id="CB027_ebu_PB-l-13">Concentre plut&#244;t sur Dieu</l>
          <l n="14" rend="indent(2)" xml:id="CB027_ebu_PB-l-14">ta pens&#233;e,</l>
          <l n="15" rend="indent(1)" xml:id="CB027_ebu_PB-l-15">cherche &#224; corriger</l>
          <l n="16" rend="indent(1)" xml:id="CB027_ebu_PB-l-16">d&#8217;abord tes actions,</l>
          <l n="17" xml:id="CB027_ebu_PB-l-17">et du travail de tes mains,</l>
          <l n="18" xml:id="CB027_ebu_PB-l-18">&#224; la sueur de ton front,</l>
          <l n="19" rend="indent(1)" xml:id="CB027_ebu_PB-l-19">gagne ton pain !</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>