  <text>
    <body>
      <div type="poem">
        <lg type="strophe" xml:id="CB021_PB-lg-1">
          <l n="1" xml:id="CB021_PB-l-1">V&#233;rit&#233; des v&#233;rit&#233;s,</l>
          <l n="2" xml:id="CB021_PB-l-2">voie, vie et v&#233;rit&#233;,</l>
          <l n="3" xml:id="CB021_PB-l-3">par tes chemins de v&#233;rit&#233;</l>
          <l n="4" xml:id="CB021_PB-l-4">tu &#233;limines le p&#233;ch&#233; !</l>
          <l n="5" xml:id="CB021_PB-l-5">La foi, l&#8217;espoir, la charit&#233;</l>
          <l n="6" xml:id="CB021_PB-l-6">te proclament Verbe incarn&#233;,</l>
          <l n="7" xml:id="CB021_PB-l-7">tu restaures pour le coupable</l>
          <l n="8" xml:id="CB021_PB-l-8">l&#8217;&#233;tat de la paix initiale,</l>
          <l n="9" xml:id="CB021_PB-l-9">apr&#232;s les d&#233;lices charnelles</l>
          <l n="10" xml:id="CB021_PB-l-10">tu donnes l&#8217;&#233;tat de gr&#226;ce pour faire un bienheureux.</l>
          <l n="11" xml:id="CB021_PB-l-11">Oh quel &#233;tonnant pouvoir,</l>
          <l n="12" xml:id="CB021_PB-l-12">quelle voix de prince royal,</l>
          <l n="13" xml:id="CB021_PB-l-13">quand tu ordonnes &#224; l&#8217;infirme :</l>
          <l n="14" xml:id="CB021_PB-l-14">&#171; Debout, prends ton grabat et marche! &#187;</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>