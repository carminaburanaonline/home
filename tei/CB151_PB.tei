<TEI>
  <teiHeader/>
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB151_PB-lg-1">
          <l n="1" xml:id="CB151_PB-l-1">Voici verdir les pr&#233;s,</l>
          <l n="2" xml:id="CB151_PB-l-2">la hargne de l&#8217;hiver est balay&#233;e,</l>
          <l n="3" xml:id="CB151_PB-l-3">les fleurs, ces dons plaisants &#224; tous,</l>
          <l n="4" xml:id="CB151_PB-l-4">rient &#224; plein visage.</l>
          <l n="5" xml:id="CB151_PB-l-5">Sous les rayons du soleil</l>
          <l n="6" xml:id="CB151_PB-l-6">brillantes, blanches, roses, &#233;blouissantes,</l>
          <l n="7" xml:id="CB151_PB-l-7">elles d&#233;voilent la loi du printemps</l>
          <l n="8" xml:id="CB151_PB-l-8">par la diversit&#233; de leur &#233;panouissement.</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB151_PB-lg-2">
          <l n="1" xml:id="CB151_PB-l-9">Les oiseaux bavards s&#8217;&#233;gosillent</l>
          <l n="2" xml:id="CB151_PB-l-10">de leur douce m&#233;lodie,</l>
          <l n="3" xml:id="CB151_PB-l-11">en tous sens, la voix attendrie,</l>
          <l n="4" xml:id="CB151_PB-l-12">ils volent affair&#233;s.</l>
          <l n="5" xml:id="CB151_PB-l-13">Et dans les bois naissent</l>
          <l n="6" xml:id="CB151_PB-l-14">feuilles, fleurs, odeurs :</l>
          <l n="7" xml:id="CB151_PB-l-15">par un temps pareil</l>
          <l n="8" xml:id="CB151_PB-l-16">s&#8217;enflamme la jeunesse.</l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB151_PB-lg-3">
          <l n="1" xml:id="CB151_PB-l-17">La troupe des jeunes gens</l>
          <l n="2" xml:id="CB151_PB-l-18">se rassemble et grandit,</l>
          <l n="3" xml:id="CB151_PB-l-19">le ch&#339;ur/le ballet des jeunes filles</l>
          <l n="4" xml:id="CB151_PB-l-20">s&#8217;unit dans la liesse commune.</l>
          <l n="5" rend="indent(1)" xml:id="CB151_PB-l-21">Et sous les tilleuls</l>
          <l n="6" xml:id="CB151_PB-l-22">vers les danses amoureuses</l>
          <l n="7" xml:id="CB151_PB-l-23">bondit une m&#232;re,</l>
          <l n="8" rend="indent(1)" xml:id="CB151_PB-l-24">sa fille avec elle.</l>
        </lg>
        <lg type="strophe" n="IV" xml:id="CB151_PB-lg-4">
          <l n="1" xml:id="CB151_PB-l-25">Entre toutes il en est une,  que la fortune</l>
          <l n="2" rend="indent(1)" xml:id="CB151_PB-l-26">m&#8217;a accord&#233; de v&#233;n&#233;rer,</l>
          <l n="3" xml:id="CB151_PB-l-27">&#233;clair&#233;e sous la lune opportune,</l>
          <l n="4" xml:id="CB151_PB-l-28">pour laquelle je suis bless&#233;</l>
          <l n="5" rend="indent(1)" xml:id="CB151_PB-l-29">et secou&#233; de soupirs.</l>
          <l n="6" xml:id="CB151_PB-l-30">Incomparable, simple et droite,</l>
          <l n="7" xml:id="CB151_PB-l-31">&#224; mon c&#339;ur elle s&#8217;est impos&#233;e</l>
          <l n="8" rend="indent(1)" xml:id="CB151_PB-l-32">et ma tristesse est oubli&#233;e.</l>
        </lg>
        <lg type="strophe" n="V" xml:id="CB151_PB-lg-5">
          <l n="1" xml:id="CB151_PB-l-33">Quand je la vois, je crois</l>
          <l n="2" xml:id="CB151_PB-l-34">que le ciel s&#8217;incline vers moi.</l>
          <l n="3" xml:id="CB151_PB-l-35">Rien ne m&#8217;est plus rien, si je peux</l>
          <l n="4" xml:id="CB151_PB-l-36">tendrement toute seule l&#8217;&#233;tendre.</l>
          <l n="5" xml:id="CB151_PB-l-37">C&#8217;est elle que je d&#233;sire</l>
          <l n="6" xml:id="CB151_PB-l-38">enlacer et plier sous moi</l>
          <l n="7" xml:id="CB151_PB-l-39">en secret, dans un lieu plaisant,</l>
          <l n="8" xml:id="CB151_PB-l-40">si je peux y arriver !</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>