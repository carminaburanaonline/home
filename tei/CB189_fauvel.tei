  <text>
    <body>
      <div type="poem" met="5x7pp/4pp/2x7pp/2x8p/2x7pp/6p">
        <lg type="strophe" met="7pp/7pp/7pp/7pp/7pp/4pp/7pp/7pp/8p/8p/7pp/7pp/6p" rhyme="a/b/b/a/c/d/d/c/e/e/c/c/e" xml:id="CB189_fauvel-lg-1">
          <l n="1" xml:id="CB189_fauvel-l-1">
            <w>Vade</w>
            <w>retro</w>
            <pc resp="#editor">,</pc>
            <w>Sathana</w>
            <pc resp="#editor">,</pc>
          </l>
          <l n="2" xml:id="CB189_fauvel-l-2">
            <w>tuas</w>
            <w>tolle</w>
            <w>fabulas</w>
            <pc resp="#editor">!</pc>
          </l>
          <l n="3" xml:id="CB189_fauvel-l-3">
            <w>Quicquid</w>
            <w>enim</w>
            <w>consulas</w>
            <pc resp="#editor">,</pc>
          </l>
          <l n="4" xml:id="CB189_fauvel-l-4">
            <w>falsitatis</w>
            <w>organa</w>
            <pc resp="#editor">,</pc>
          </l>
          <l n="5" xml:id="CB189_fauvel-l-5">
            <w>voces</w>
            <w>adulancium</w>
            <pc resp="#editor">,</pc>
          </l>
          <l n="6" xml:id="CB189_fauvel-l-6">
            <w>devoveo</w>
            <pc resp="#editor">,</pc>
          </l>
          <l n="7" xml:id="CB189_fauvel-l-7">
            <w>nulliusque</w>
            <w>foveo</w>
          </l>
          <l n="8" xml:id="CB189_fauvel-l-8">
            <w>blandiendo</w>
            <w>vicium</w>
            <pc resp="#editor">;</pc>
          </l>
          <l n="9" xml:id="CB189_fauvel-l-9">
            <w>sed</w>
            <w>Palponis</w>
            <w>nomen</w>
            <w>cavi</w>
            <pc resp="#editor">,</pc>
          </l>
          <l n="10" xml:id="CB189_fauvel-l-10">
            <w>cuius</w>
            <w>semper</w>
            <w>declinavi</w>
          </l>
          <l n="11" xml:id="CB189_fauvel-l-11">
            <w>fraudis</w>
            <w>artificium</w>
            <pc resp="#editor">.</pc>
          </l>
          <l n="12" xml:id="CB189_fauvel-l-12">
            <w>Tuum</w>
            <w>factum</w>
            <w>noxium</w>
          </l>
          <l n="13" xml:id="CB189_fauvel-l-13">
            <w>nosce</w>
            <pc resp="#editor">,</pc>
            <w>dic</w>
            <pc resp="#editor">:</pc>
            <w>erravi</w>
            <pc resp="#editor">.</pc>
          </l>
        </lg>
      </div>
