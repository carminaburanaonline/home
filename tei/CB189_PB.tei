<TEI>
  <teiHeader />
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="1a" xml:id="CB189_PB-lg-1">
          <l n="1" xml:id="CB189_PB-l-1">&#171; Aristippe, bien qu&#8217;un peu tard,</l>
          <l n="2" xml:id="CB189_PB-l-2">je voudrais &#224; la fin pourtant</l>
          <l n="3" rend="indent(1)" xml:id="CB189_PB-l-3">que tu me conseilles :</l>
          <l n="4" rend="indent(1)" xml:id="CB189_PB-l-4">Qu&#8217;irais-je faire &#224; Rome ?</l>
          <l n="5" rend="indent(1)" xml:id="CB189_PB-l-5">Je ne sais pas mentir.</l>
          <l n="6" rend="indent(1)" xml:id="CB189_PB-l-6">La faveur des puissants</l>
          <l n="7" rend="indent(1)" xml:id="CB189_PB-l-7">s&#8217;obtient par flatterie.</l>
          <l n="8" xml:id="CB189_PB-l-8">Si je m&#8217;attache au vrai, qui blesse,</l>
          <l n="9" xml:id="CB189_PB-l-9">Verr&#232;s ne m&#8217;aimera jamais.</l>
          <l n="10" rend="indent(1)" xml:id="CB189_PB-l-10">Un histrion m&#233;rite</l>
          <l n="11" rend="indent(1)" xml:id="CB189_PB-l-11">le prix de vertu</l>
          <l n="12" rend="indent(1)" xml:id="CB189_PB-l-12">quand il flatte le vice</l>
          <l n="13" rend="indent(1)" xml:id="CB189_PB-l-13">par ses plaisants mensonges. &#187;</l>
        </lg>
        <lg type="strophe" n="1b" xml:id="CB189_PB-lg-2">
          <l n="1" xml:id="CB189_PB-l-14">&#171; Diog&#232;ne, quel est ton but ?</l>
          <l n="2" xml:id="CB189_PB-l-15">Veux-tu des honneurs, des pr&#233;bendes ?</l>
          <l n="3" rend="indent(1)" xml:id="CB189_PB-l-16">Explique-toi d&#8217;abord !</l>
          <l n="4" rend="indent(1)" xml:id="CB189_PB-l-17">Les pr&#233;lats des &#233;glises</l>
          <l n="5" rend="indent(1)" xml:id="CB189_PB-l-18">ne t&#8217;appr&#233;cient pas</l>
          <l n="6" rend="indent(1)" xml:id="CB189_PB-l-19">si tu ne t&#8217;impliques pas</l>
          <l n="7" rend="indent(1)" xml:id="CB189_PB-l-20">avec eux dans leurs vices.</l>
          <l n="8" xml:id="CB189_PB-l-21">Si tu approuves chez les pr&#233;lats</l>
          <l n="9" xml:id="CB189_PB-l-22">leur vie fautive, on t&#8217;aimera !</l>
          <l n="10" rend="indent(1)" xml:id="CB189_PB-l-23">Nos saints pontifes</l>
          <l n="11" rend="indent(1)" xml:id="CB189_PB-l-24">pr&#233;f&#232;rent de beaucoup</l>
          <l n="12" rend="indent(1)" xml:id="CB189_PB-l-25">ceux qui sont leurs complices,</l>
          <l n="13" rend="indent(1)" xml:id="CB189_PB-l-26">ministres de leurs crimes. &#187;</l>
        </lg>
        <lg type="strophe" n="2a" xml:id="CB189_PB-lg-3">
          <l n="1" rend="indent(1)" xml:id="CB189_PB-l-27">&#171; Aux vices des puissants</l>
          <l n="2" rend="indent(1)" xml:id="CB189_PB-l-28">je ne sais pas applaudir,</l>
          <l n="3" rend="indent(1)" xml:id="CB189_PB-l-29">ni rechercher leur faveur</l>
          <l n="4" rend="indent(1)" xml:id="CB189_PB-l-30">en parlant d&#8217;un c&#339;ur menteur.</l>
          <l n="5" rend="indent(1)" xml:id="CB189_PB-l-31">Toujours je fais parler</l>
          <l n="6" rend="indent(1)" xml:id="CB189_PB-l-32">la simple v&#233;rit&#233;,</l>
          <l n="7" rend="indent(1)" xml:id="CB189_PB-l-33">j&#8217;ai peine &#224; voir louer</l>
          <l n="8" rend="indent(1)" xml:id="CB189_PB-l-34">quelqu&#8217;un outre ses m&#233;rites,</l>
          <l n="9" rend="indent(1)" xml:id="CB189_PB-l-35">et je ne couvre pas de fleurs</l>
          <l n="10" rend="indent(1)" xml:id="CB189_PB-l-36">la t&#234;te d&#8217;un p&#233;cheur. &#187;</l>
        </lg>
        <lg type="strophe" n="2b" xml:id="CB189_PB-lg-4">
          <l n="1" rend="indent(1)" xml:id="CB189_PB-l-37">&#171; Eh bien, va-t&#8217;en bien loin</l>
          <l n="2" rend="indent(1)" xml:id="CB189_PB-l-38">si tu r&#233;pugnes &#224; mentir !</l>
          <l n="3" rend="indent(1)" xml:id="CB189_PB-l-39">Dire la simple v&#233;rit&#233;</l>
          <l n="4" rend="indent(1)" xml:id="CB189_PB-l-40">en a fait beaucoup exiler !</l>
          <l n="5" rend="indent(1)" xml:id="CB189_PB-l-41">Entoure nos pr&#233;lats</l>
          <l n="6" rend="indent(1)" xml:id="CB189_PB-l-42">de douces flatteries,</l>
          <l n="7" rend="indent(1)" xml:id="CB189_PB-l-43">et ne va pas les irriter</l>
          <l n="8" rend="indent(1)" xml:id="CB189_PB-l-44">en parlant mal des vices,</l>
          <l n="9" rend="indent(1)" xml:id="CB189_PB-l-45">si tu d&#233;sires profiter</l>
          <l n="10" rend="indent(1)" xml:id="CB189_PB-l-46">de leurs b&#233;n&#233;fices. &#187;</l>
        </lg>
        <lg type="strophe" n="3a" xml:id="CB189_PB-lg-5">
          <l n="1" rend="indent(1)" xml:id="CB189_PB-l-47">&#171; Alors, selon ton conseil,</l>
          <l n="2" rend="indent(1)" xml:id="CB189_PB-l-48">il est bon que je me taise,</l>
          <l n="3" rend="indent(1)" xml:id="CB189_PB-l-49">ou qu&#8217;en les flattant je plaise</l>
          <l n="4" rend="indent(1)" xml:id="CB189_PB-l-50">aux d&#233;licates oreilles</l>
          <l n="5" rend="indent(2)" xml:id="CB189_PB-l-51">des puissants,</l>
          <l n="6" rend="indent(1)" xml:id="CB189_PB-l-52">&#224; qui tu veux qu&#8217;ainsi je plaise ?</l>
          <l n="7" rend="indent(1)" xml:id="CB189_PB-l-53">L&#8217;adulation ou le silence,</l>
          <l n="8" rend="indent(1)" xml:id="CB189_PB-l-54">tu n&#8217;as pas d&#8217;autre solution ;</l>
          <l n="9" rend="indent(1)" xml:id="CB189_PB-l-55">ainsi, comme si j&#8217;approuvais,</l>
          <l n="10" rend="indent(1)" xml:id="CB189_PB-l-56">je me trouverais complice</l>
          <l n="11" rend="indent(1)" xml:id="CB189_PB-l-57">de la faute d&#8217;autrui ! &#187;</l>
        </lg>
        <lg type="strophe" n="3b" xml:id="CB189_PB-lg-6">
          <l n="1" rend="indent(1)" xml:id="CB189_PB-l-58">&#171; Ne crains pas de te souiller</l>
          <l n="2" rend="indent(1)" xml:id="CB189_PB-l-59">en prenant part au p&#233;ch&#233; :</l>
          <l n="3" rend="indent(1)" xml:id="CB189_PB-l-60">car si tu veux profiter</l>
          <l n="4" rend="indent(1)" xml:id="CB189_PB-l-61">de la faveur des puissants,</l>
          <l n="5" rend="indent(2)" xml:id="CB189_PB-l-62">prends part &#224; leur vice.</l>
          <l n="6" rend="indent(1)" xml:id="CB189_PB-l-63">Les plus grands de nos pr&#233;lats</l>
          <l n="7" rend="indent(1)" xml:id="CB189_PB-l-64">aiment qu&#8217;en vivant comme eux</l>
          <l n="8" rend="indent(1)" xml:id="CB189_PB-l-65">leurs ministres leur ressemblent :</l>
          <l n="9" rend="indent(1)" xml:id="CB189_PB-l-66">des complices de Giezi,</l>
          <l n="10" rend="indent(1)" xml:id="CB189_PB-l-67">des Prot&#233;es en leurs promesses,</l>
          <l n="11" rend="indent(1)" xml:id="CB189_PB-l-68">et des disciples d&#8217;Orph&#233;e. &#187;</l>
        </lg>
        <lg type="strophe" n="4a" xml:id="CB189_PB-lg-7">
          <l n="1" rend="indent(1)" xml:id="CB189_PB-l-69">&#171; Arri&#232;re, arri&#232;re, Satan !</l>
          <l n="2" rend="indent(1)" xml:id="CB189_PB-l-70">Arr&#234;te avec tes histoires !</l>
          <l n="3" rend="indent(1)" xml:id="CB189_PB-l-71">Car quel que soit ton conseil,</l>
          <l n="4" rend="indent(1)" xml:id="CB189_PB-l-72">les paroles mensong&#232;res,</l>
          <l n="5" rend="indent(1)" xml:id="CB189_PB-l-73">les voix des adulateurs,</l>
          <l n="6" rend="indent(2)" xml:id="CB189_PB-l-74">je les maudis,</l>
          <l n="7" rend="indent(1)" xml:id="CB189_PB-l-75">et je ne cajole personne</l>
          <l n="8" rend="indent(1)" xml:id="CB189_PB-l-76">en favorisant son vice ;</l>
          <l n="9" rend="indent(1)" xml:id="CB189_PB-l-77">j&#8217;&#233;vite le nom de Flatteur,</l>
          <l n="10" rend="indent(1)" xml:id="CB189_PB-l-78">car j&#8217;ai toujours refus&#233;</l>
          <l n="11" rend="indent(1)" xml:id="CB189_PB-l-79">ses man&#339;uvres de trompeur. &#187;</l>
        </lg>
        <lg type="strophe" n="4b" xml:id="CB189_PB-lg-8">
          <l n="1" rend="indent(1)" xml:id="CB189_PB-l-80">&#171; Donc que tu vives de peu,</l>
          <l n="2" rend="indent(1)" xml:id="CB189_PB-l-81">et te contentes de ce peu.</l>
          <l n="3" rend="indent(1)" xml:id="CB189_PB-l-82">De rien n&#8217;a besoin un cynique.</l>
          <l n="4" rend="indent(1)" xml:id="CB189_PB-l-83">Si tu veux &#234;tre un cynique,</l>
          <l n="5" rend="indent(1)" xml:id="CB189_PB-l-84">dis adieu aux cours et va-t&#8217;en,</l>
          <l n="6" rend="indent(2)" xml:id="CB189_PB-l-85">et qu&#8217;ainsi</l>
          <l n="7" rend="indent(1)" xml:id="CB189_PB-l-86">tu ne sois pas en situation</l>
          <l n="8" rend="indent(1)" xml:id="CB189_PB-l-87">de devoir applaudir aux vices.</l>
          <l n="9" rend="indent(1)" xml:id="CB189_PB-l-88">Car le m&#233;chant te rend m&#233;chant</l>
          <l n="10" rend="indent(1)" xml:id="CB189_PB-l-89">si tu cherches &#224; &#234;tre bien vu</l>
          <l n="11" rend="indent(1)" xml:id="CB189_PB-l-90">de la compagnie des puissants. &#187;</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>