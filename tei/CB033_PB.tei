<TEI>
  <teiHeader/>
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB033_PB-lg-1">
          <l n="1" xml:id="CB033_PB-l-1">N&#8217;aie pas honte de t&#8217;&#234;tre amus&#233;,</l>
          <l n="2" xml:id="CB033_PB-l-2">mais de ne pas cesser de le faire,</l>
          <l n="3" xml:id="CB033_PB-l-3">et ce que tu fis mal &#224; propos</l>
          <l n="4" xml:id="CB033_PB-l-4">change-le en vie r&#233;gl&#233;e.</l>
          <l n="5" xml:id="CB033_PB-l-5">Que la raison, ma&#238;tresse de m&#339;urs,</l>
          <l n="6" rend="indent(1)" xml:id="CB033_PB-l-6">t&#8217;enseigne,</l>
          <l n="7" xml:id="CB033_PB-l-7">pour qu&#8217;en rejetant loin les vices</l>
          <l n="8" xml:id="CB033_PB-l-8">tu sois lav&#233; de tes souillures,</l>
          <l n="9" xml:id="CB033_PB-l-9">et qu&#8217;en louant la Vierge pure</l>
          <l n="10" xml:id="CB033_PB-l-10">tu puisses officier &#224; l&#8217;autel.</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB033_PB-lg-2">
          <l n="1" xml:id="CB033_PB-l-11">Que tu sois pieux, sobre et juste,</l>
          <l n="2" xml:id="CB033_PB-l-12">prudent, et pudique, et humble,</l>
          <l n="3" xml:id="CB033_PB-l-13">&#224; la loi divine docile ;</l>
          <l n="4" xml:id="CB033_PB-l-14">ne sois pas un arbre st&#233;rile.</l>
          <l n="5" xml:id="CB033_PB-l-15">Que ta conduite s&#8217;adapte au mieux</l>
          <l n="6" rend="indent(1)" xml:id="CB033_PB-l-16">&#224; ton office,</l>
          <l n="7" xml:id="CB033_PB-l-17">pour que, digne de pr&#233;lature</l>
          <l n="8" xml:id="CB033_PB-l-18">par don du bon vouloir de Dieu,</l>
          <l n="9" xml:id="CB033_PB-l-19">tu remplisses ton sacerdoce</l>
          <l n="10" xml:id="CB033_PB-l-20">en louange du nom du Christ.</l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB033_PB-lg-3">
          <l n="1" xml:id="CB033_PB-l-21">Ne donne pas, faussement pieux,</l>
          <l n="2" xml:id="CB033_PB-l-22">aux serviteurs pourris, des biens</l>
          <l n="3" xml:id="CB033_PB-l-23">qui sont d&#8217;&#201;glise, et non pas tiens.</l>
          <l n="4" xml:id="CB033_PB-l-24">N&#8217;abuse pas, impiement,</l>
          <l n="5" xml:id="CB033_PB-l-25">de dons faits pour aider les pauvres,</l>
          <l n="6" rend="indent(1)" xml:id="CB033_PB-l-26">&#224; toi confi&#233;s.</l>
          <l n="7" xml:id="CB033_PB-l-27">Ne donne rien au com&#233;dien,</l>
          <l n="8" xml:id="CB033_PB-l-28">et ne te concilie pas</l>
          <l n="9" xml:id="CB033_PB-l-29">des amiti&#233;s scandaleuses</l>
          <l n="10" xml:id="CB033_PB-l-30">gr&#226;ce au patrimoine du Christ.</l>
        </lg>
        <lg type="strophe" n="IV" xml:id="CB033_PB-lg-4">
          <l n="1" xml:id="CB033_PB-l-31">Repousse bien loin de toi</l>
          <l n="2" xml:id="CB033_PB-l-32">les subordonn&#233;s corrompus :</l>
          <l n="3" xml:id="CB033_PB-l-33">car un compagnon d&#233;prav&#233;</l>
          <l n="4" xml:id="CB033_PB-l-34">d&#233;prave trop la vie des bons</l>
          <l n="5" xml:id="CB033_PB-l-35">et la frappe du d&#233;ficit</l>
          <l n="6" rend="indent(1)" xml:id="CB033_PB-l-36">de l&#8217;infamie.</l>
          <l n="7" xml:id="CB033_PB-l-37">On tire des pr&#233;somptions</l>
          <l n="8" xml:id="CB033_PB-l-38">de semblable compagnonnage.</l>
          <l n="9" xml:id="CB033_PB-l-39">Habiter avec des gens vils</l>
          <l n="10" xml:id="CB033_PB-l-40">rend vile la vie d&#8217;un pr&#233;lat.</l>
        </lg>
        <lg type="strophe" n="V" xml:id="CB033_PB-lg-5">
          <l n="1" xml:id="CB033_PB-l-41">R&#232;gle prudemment ta maison,</l>
          <l n="2" xml:id="CB033_PB-l-42">parle peu, mais en v&#233;rit&#233;,</l>
          <l n="3" xml:id="CB033_PB-l-43">en acte accomplis tes promesses :</l>
          <l n="4" xml:id="CB033_PB-l-44">il ne convient pas qu&#8217;un mensonge</l>
          <l n="5" xml:id="CB033_PB-l-45">salisse la bouche d&#8217;un pr&#234;tre</l>
          <l n="6" rend="indent(1)" xml:id="CB033_PB-l-46">&#224; la l&#233;g&#232;re ;</l>
          <l n="7" xml:id="CB033_PB-l-47">laisse-toi sans d&#233;sagr&#233;ment</l>
          <l n="8" xml:id="CB033_PB-l-48">conseiller par les gens prudents,</l>
          <l n="9" xml:id="CB033_PB-l-49">qu&#8217;une exhortation salutaire</l>
          <l n="10" xml:id="CB033_PB-l-50">ne te mette pas en col&#232;re.</l>
        </lg>
        <lg type="strophe" n="VI" xml:id="CB033_PB-lg-6">
          <l n="1" xml:id="CB033_PB-l-51">Tu es tenu de t&#8217;abstenir</l>
          <l n="2" xml:id="CB033_PB-l-52">de toute f&#226;cheuse apparence ;</l>
          <l n="3" xml:id="CB033_PB-l-53">bien brid&#233; par la temp&#233;rance,</l>
          <l n="4" xml:id="CB033_PB-l-54">sois en fleur, la sobri&#233;t&#233;</l>
          <l n="5" xml:id="CB033_PB-l-55">t&#8217;enseignant la pudicit&#233;,</l>
          <l n="6" rend="indent(1)" xml:id="CB033_PB-l-56">et ne va pas</l>
          <l n="7" xml:id="CB033_PB-l-57">par un d&#233;sir vague et variable</l>
          <l n="8" xml:id="CB033_PB-l-58">te plonger dans les tentations,</l>
          <l n="9" xml:id="CB033_PB-l-59">mais d&#8217;un rayon de vertu chasse</l>
          <l n="10" xml:id="CB033_PB-l-60">les ombres d&#8217;un esprit aveugle.</l>
        </lg>
        <lg type="strophe" n="VII" xml:id="CB033_PB-lg-7">
          <l n="1" xml:id="CB033_PB-l-61">G&#233;n&#233;reux protecteur des pauvres,</l>
          <l n="2" xml:id="CB033_PB-l-62">donne &#224; tous ceux qui le demandent,</l>
          <l n="3" xml:id="CB033_PB-l-63">reprends fortement les m&#233;chants ;</l>
          <l n="4" xml:id="CB033_PB-l-64">nettoie tes mains consacr&#233;es</l>
          <l n="5" xml:id="CB033_PB-l-65">de la corruption de cadeaux</l>
          <l n="6" rend="indent(1)" xml:id="CB033_PB-l-66">inavouables,</l>
          <l n="7" xml:id="CB033_PB-l-67">que nul  ne puisse t&#8217;acheter ;</l>
          <l n="8" xml:id="CB033_PB-l-68">distribue les b&#233;n&#233;fices</l>
          <l n="9" xml:id="CB033_PB-l-69">quand on les demande gratis,</l>
          <l n="10" xml:id="CB033_PB-l-70">mais &#224; ceux qui en seront dignes.</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>