  <teiHeader />
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB167_PB-lg-1">
          <l n="1" xml:id="CB167_PB-l-1">Le rem&#232;de &#224; la peine</l>
          <l n="2" xml:id="CB167_PB-l-2">de qui s&#8217;en va, c&#8217;est sa joie.</l>
          <l n="3" xml:id="CB167_PB-l-3">Le souvenir de mon amie</l>
          <l n="4" xml:id="CB167_PB-l-4">adoucit mon exil.</l>
          <l n="5" xml:id="CB167_PB-l-5">Ma seule consolation,</l>
          <l n="6" xml:id="CB167_PB-l-6">c&#8217;est l&#8217;affection qu&#8217;elle a pour moi.</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB167_PB-lg-2">
          <l n="1" xml:id="CB167_PB-l-7">Sans m&#8217;avancer hardiment,</l>
          <l n="2" xml:id="CB167_PB-l-8">je l&#8217;aimais bien tendrement,</l>
          <l n="3" xml:id="CB167_PB-l-9">sachant qu&#8217;elle &#233;tait encore</l>
          <l n="4" xml:id="CB167_PB-l-10">d&#8217;un &#226;ge bien tendre,</l>
          <l n="5" xml:id="CB167_PB-l-11">et n&#8217;osant rien exiger</l>
          <l n="6" xml:id="CB167_PB-l-12">hors l&#8217;accord de nos esprits.</l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB167_PB-lg-3">
          <l n="1" xml:id="CB167_PB-l-13">Je br&#251;le pour elle absente,</l>
          <l n="2" xml:id="CB167_PB-l-14">car V&#233;nus d&#8217;une cha&#238;ne d&#8217;or</l>
          <l n="3" xml:id="CB167_PB-l-15">tient nos c&#339;urs reli&#233;s</l>
          <l n="4" xml:id="CB167_PB-l-16">par la distance des corps.</l>
          <l n="5" xml:id="CB167_PB-l-17">Triste, je jouis pourtant</l>
          <l n="6" xml:id="CB167_PB-l-18">de la pr&#233;sence de l&#8217;absente.</l>
        </lg>
        <lg type="strophe" n="IV" xml:id="CB167_PB-lg-4">
          <l n="1" xml:id="CB167_PB-l-19">Mais voil&#224; qu&#8217;elle a grandi,</l>
          <l n="2" xml:id="CB167_PB-l-20">que l&#8217;amour s&#8217;est enflamm&#233;,</l>
          <l n="3" xml:id="CB167_PB-l-21">que la pucelle a m&#251;ri,</l>
          <l n="4" xml:id="CB167_PB-l-22">que ses seins se sont gonfl&#233;s.</l>
          <l n="5" xml:id="CB167_PB-l-23">Voil&#224; qu&#8217;elle m&#8217;a plu en vain</l>
          <l n="6" xml:id="CB167_PB-l-24">si le reste ne suit pas.</l>
        </lg>
        <lg type="strophe" n="V" xml:id="CB167_PB-lg-5">
          <l n="1" xml:id="CB167_PB-l-25">Donc puisque nos c&#339;urs sont joints</l>
          <l n="2" xml:id="CB167_PB-l-26">joignons-nous aussi de fait</l>
          <l n="3" xml:id="CB167_PB-l-27">Jouissons en plein bonheur</l>
          <l n="4" xml:id="CB167_PB-l-28">de savoureuses &#233;treintes !</l>
          <l n="5" xml:id="CB167_PB-l-29">Fleur entre toutes fleurie,</l>
          <l n="6" xml:id="CB167_PB-l-30">jouons ensemble pour de bon !</l>
        </lg>
        <lg type="strophe" n="VI" xml:id="CB167_PB-lg-6">
          <l n="1" xml:id="CB167_PB-l-31">Presser le fruit de la vigne,</l>
          <l n="2" xml:id="CB167_PB-l-32">boire le miel &#224; sa source,</l>
          <l n="3" xml:id="CB167_PB-l-33">ce que c&#8217;est, ma douce enfant,</l>
          <l n="4" xml:id="CB167_PB-l-34">je voudrais te le montrer.</l>
          <l n="5" xml:id="CB167_PB-l-35">Mais que cette explication</l>
          <l n="6" xml:id="CB167_PB-l-36">soit de fait, non de parole !</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>