  <teiHeader />
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB131_en_1003_PB-lg-1">
          <l n="1" xml:id="CB131_en_1003_PB-l-1">Dis, V&#233;rit&#233; du Christ,</l>
          <l n="2" xml:id="CB131_en_1003_PB-l-2">dis, toi si rare et ch&#232;re,</l>
          <l n="3" xml:id="CB131_en_1003_PB-l-3">dis, rare Charit&#233;,</l>
          <l n="4" xml:id="CB131_en_1003_PB-l-4">o&#249; es-tu &#224; pr&#233;sent ?</l>
          <l n="5" xml:id="CB131_en_1003_PB-l-5">Dans la vall&#233;e des visions ?</l>
          <l n="6" xml:id="CB131_en_1003_PB-l-6">Sur le tr&#244;ne de Pharaon ?</l>
          <l n="7" xml:id="CB131_en_1003_PB-l-7">Ou au pinacle avec N&#233;ron ?</l>
          <l n="8" xml:id="CB131_en_1003_PB-l-8">Ou dans la grotte avec Th&#233;on ?</l>
          <l n="9" xml:id="CB131_en_1003_PB-l-9">Ou dans la corbeille d&#8217;osier</l>
          <l n="10" xml:id="CB131_en_1003_PB-l-10">avec l&#8217;enfant Mo&#239;se en larmes ?</l>
          <l n="11" xml:id="CB131_en_1003_PB-l-11">Ou dans la Demeure romaine</l>
          <l n="12" xml:id="CB131_en_1003_PB-l-12">avec la Bulle fulmin&#233;e ?</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB131_en_1003_PB-lg-2">
          <l n="1" xml:id="CB131_en_1003_PB-l-13">La Charit&#233; r&#233;pond :</l>
          <l n="2" xml:id="CB131_en_1003_PB-l-14">&#171; Homme, pourquoi douter ?</l>
          <l n="3" xml:id="CB131_en_1003_PB-l-15">Pourquoi me harceler ?</l>
          <l n="4" xml:id="CB131_en_1003_PB-l-16">Je ne suis pas o&#249; tu vas chercher,</l>
          <l n="5" xml:id="CB131_en_1003_PB-l-17">ni &#224; l&#8217;est ni au midi,</l>
          <l n="6" xml:id="CB131_en_1003_PB-l-18">ni sur la place ni au couvent,</l>
          <l n="7" xml:id="CB131_en_1003_PB-l-19">ni au combat ni au pouvoir :</l>
          <l n="8" xml:id="CB131_en_1003_PB-l-20">ni sous le lin ni sous la bure,</l>
          <l n="9" xml:id="CB131_en_1003_PB-l-21">je viens toujours de J&#233;richo</l>
          <l n="10" xml:id="CB131_en_1003_PB-l-22">et je pleure avec le bless&#233;,</l>
          <l n="11" xml:id="CB131_en_1003_PB-l-23">celui que n&#8217;ont pas assist&#233;</l>
          <l n="12" xml:id="CB131_en_1003_PB-l-24">sur son lit de douleur,</l>
          <l n="13" xml:id="CB131_en_1003_PB-l-25">les deux pr&#234;tres qui sont pass&#233;s. &#187;</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>