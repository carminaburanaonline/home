<TEI>
  <teiHeader/>
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB146_PB-lg-1">
          <l n="1" xml:id="CB146_PB-l-1">La terre se rev&#234;t de fleurs multicolores,</l>
          <l n="2" xml:id="CB146_PB-l-2">le printemps fait enfin sentir qu&#8217;il est pr&#233;sent.</l>
          <l n="3" xml:id="CB146_PB-l-3">On entend doucement chanter le rossignol,</l>
          <l n="4" xml:id="CB146_PB-l-4">c&#8217;en est donc bien fini des rigueurs de l&#8217;hiver.</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB146_PB-lg-2">
          <l n="1" xml:id="CB146_PB-l-5">
            <seg type="hemistich">Ses joues sont vermeilles,</seg>
            <seg type="hemistich">ses cheveux s&#233;par&#233;s</seg>
          </l>
          <l n="2" xml:id="CB146_PB-l-6">d&#233;gagent bien son front en deux bandeaux obliques,</l>
          <l n="3" xml:id="CB146_PB-l-7">
            <seg type="hemistich">tout son visage rit.</seg>
            <seg type="hemistich">Oh combien bienheureuse</seg>
          </l>
          <l n="4" xml:id="CB146_PB-l-8">celle qui est orn&#233;e de tant de qualit&#233;s !</l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB146_PB-lg-3">
          <l n="1" xml:id="CB146_PB-l-9">
            <seg type="hemistich">Elle a la taille fine</seg>
            <seg type="hemistich">autant qu&#8217;il est de mise,</seg>
          </l>
          <l n="2" xml:id="CB146_PB-l-10">
            <seg type="hemistich">son parfum est meilleur</seg>
            <seg type="hemistich">que n&#8217;importe quel baume.</seg>
          </l>
          <l n="3" xml:id="CB146_PB-l-11">
            <seg type="hemistich">Heureux qui peut dormir</seg>
            <seg type="hemistich">avec telle pucelle,</seg>
          </l>
          <l n="4" xml:id="CB146_PB-l-12">
            <seg type="hemistich">il sera en honneur</seg>
            <seg type="hemistich">l&#8217;&#233;gal des dieux du ciel.</seg>
          </l>
        </lg>
        <lg type="strophe" n="IV" xml:id="CB146_PB-lg-4">
          <l n="1" xml:id="CB146_PB-l-13">Quand elle rit, entre ses sourcils</l>
          <l n="2" xml:id="CB146_PB-l-14">
            <seg type="hemistich">l&#8217;espace est lisse</seg>
            <seg type="hemistich">et large &#224; souhait.</seg>
          </l>
          <l n="3" xml:id="CB146_PB-l-15">Sa bouche invite au baiser qui l&#8217;en prie.</l>
          <l n="4" xml:id="CB146_PB-l-16">A mon secours, ma dame, je succombe !</l>
        </lg>
        <lg type="strophe" n="V" xml:id="CB146_PB-lg-5">
          <l n="1" xml:id="CB146_PB-l-17">Je suis bless&#233;, je ne peux en gu&#233;rir,</l>
          <l n="2" xml:id="CB146_PB-l-18">et je n&#8217;aurai nul espoir de survivre</l>
          <l n="3" xml:id="CB146_PB-l-19">
            <seg type="hemistich">si tu ne me consoles</seg>
            <seg type="hemistich">de pr&#233;f&#233;rence aux autres,</seg>
          </l>
          <l n="4" xml:id="CB146_PB-l-20">
            <seg type="hemistich">toi qui d&#233;passes tout</seg>
            <seg type="hemistich">par ta beaut&#233; unique.</seg>
          </l>
        </lg>
      </div>
    </body>
  </text>
</TEI>