<TEI>
  <teiHeader />
  <text>
    <body>
      <div type="poem">
        <lg type="strophe" n="I" xml:id="CB164_PB-lg-1">
          <l n="1" xml:id="CB164_PB-l-1">Parce que l&#8217;amour me tourmente,</l>
          <l n="2" xml:id="CB164_PB-l-2">je vais y porter un rem&#232;de</l>
          <l n="3" xml:id="CB164_PB-l-3">efficace pour l&#8217;amant :</l>
          <l n="4" xml:id="CB164_PB-l-4">mon c&#339;ur br&#251;le int&#233;rieurement</l>
          <l n="5" xml:id="CB164_PB-l-5">et se morfond mon &#226;me jadis pure,</l>
          <l n="6" xml:id="CB164_PB-l-6">je suis tortur&#233; physiquement</l>
          <l n="7" xml:id="CB164_PB-l-7">du fait des droits de la nature.</l>
        </lg>
        <lg type="strophe" n="II" xml:id="CB164_PB-lg-2">
          <l n="1" xml:id="CB164_PB-l-8">Si je veux m&#8217;en remettre</l>
          <l n="2" xml:id="CB164_PB-l-9">et prolonger mon existence,</l>
          <l n="3" xml:id="CB164_PB-l-10">vite, allons d&#8217;un pas d&#233;cid&#233;</l>
          <l n="4" xml:id="CB164_PB-l-11">trouver Corinne, sa pr&#233;sence</l>
          <l n="5" xml:id="CB164_PB-l-12">peut me procurer l&#8217;esp&#233;rance !</l>
          <l n="6" xml:id="CB164_PB-l-13">C&#8217;est en cherchant sa bonne gr&#226;ce</l>
          <l n="7" xml:id="CB164_PB-l-14">que je cherche &#224; &#234;tre gu&#233;ri.</l>
        </lg>
        <lg type="strophe" n="III" xml:id="CB164_PB-lg-3">
          <l n="1" xml:id="CB164_PB-l-15">Car elle est facile en amour,</l>
          <l n="2" xml:id="CB164_PB-l-16">pleine de toutes qualit&#233;s :</l>
          <l n="3" xml:id="CB164_PB-l-17">son teint, la rose en rougit,</l>
          <l n="4" xml:id="CB164_PB-l-18">et en tout son parfum l&#8217;emporte</l>
          <l n="5" xml:id="CB164_PB-l-19">sur celui du lys des vall&#233;es.</l>
          <l n="6" xml:id="CB164_PB-l-20">De sa douce bouche, elle verse</l>
          <l n="7" xml:id="CB164_PB-l-21">un merveilleux g&#226;teau de miel.</l>
        </lg>
        <lg type="strophe" n="IV" xml:id="CB164_PB-lg-4">
          <l n="1" xml:id="CB164_PB-l-22">Pour la vue, elle est sans d&#233;faut,</l>
          <l n="2" xml:id="CB164_PB-l-23">l&#8217;&#233;couter n&#8217;est pas s&#8217;abaisser,</l>
          <l n="3" xml:id="CB164_PB-l-24">et son aspect est engageant/souriant.</l>
          <l n="4" xml:id="CB164_PB-l-25">Mais plus plaisant que tout cela</l>
          <l n="5" xml:id="CB164_PB-l-26">est l&#8217;endroit cach&#233; sous sa robe.</l>
          <l n="6" xml:id="CB164_PB-l-27">Pour y d&#233;cliner son s&#233;jour,</l>
          <l n="7" xml:id="CB164_PB-l-28">mieux vaut s&#8217;&#233;riger droit qu&#8217;oblique !</l>
        </lg>
        <lg type="strophe" n="V" xml:id="CB164_PB-lg-5">
          <l n="1" xml:id="CB164_PB-l-29">Si en ce lieu je m&#8217;h&#233;bergeais,</l>
          <l n="2" xml:id="CB164_PB-l-30">j&#8217;en d&#233;clinerais chaque partie,</l>
          <l n="3" xml:id="CB164_PB-l-31">cas par cas je m&#8217;y donnerais,</l>
          <l n="4" xml:id="CB164_PB-l-32">et je ne consid&#233;rerais</l>
          <l n="5" xml:id="CB164_PB-l-33">ni temps pr&#233;sent ni temps pass&#233;,</l>
          <l n="6" xml:id="CB164_PB-l-34">mais plut&#244;t je me h&#226;terais</l>
          <l n="7" xml:id="CB164_PB-l-35">vers ce que m&#233;rite ma peine.</l>
        </lg>
      </div>
    </body>
  </text>
</TEI>